<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Calibration"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_Calibration" name="Travel expense reimbursement" isExecutable="false">

    <bpmn:startEvent id="StartEvent_Submitted" name="Expense report submitted">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_Receive" name="Receive expense report">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Merge">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_Check" name="Check report and receipts">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Decision" name="Receipts missing?">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_Ask" name="Ask employee to provide missing receipts">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>

    <bpmn:eventBasedGateway id="Gateway_Event">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="Event_Msg" name="Missing receipts submitted">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_1" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Event_Timer" name="3 days">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_1" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndEvent_Rejected" name="Request rejected">
      <bpmn:incoming>Flow_10</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_Approve" name="Approval">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_Split">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_Record" name="Record expenses in accounting system">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Notify" name="Notify employee of approval">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_BadJoin">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_Pay" name="Pay reimbursement to employee">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Archive" name="Archive expense report">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_Done" name="Process completed">
      <bpmn:incoming>Flow_19</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Submitted" targetRef="Task_Receive" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_Receive" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Gateway_Merge" targetRef="Task_Check" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_Check" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="Flow_05" name="Yes" sourceRef="Gateway_Decision" targetRef="Task_Ask" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_Ask" targetRef="Gateway_Event" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Gateway_Event" targetRef="Event_Msg" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Event_Msg" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Gateway_Event" targetRef="Event_Timer" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Event_Timer" targetRef="EndEvent_Rejected" />
    <bpmn:sequenceFlow id="Flow_11" name="No" sourceRef="Gateway_Decision" targetRef="Task_Approve" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_Approve" targetRef="Gateway_Split" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Gateway_Split" targetRef="Task_Record" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Gateway_Split" targetRef="Task_Notify" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_Record" targetRef="Gateway_BadJoin" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_Notify" targetRef="Gateway_BadJoin" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Gateway_BadJoin" targetRef="Task_Pay" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_Pay" targetRef="Task_Archive" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="Task_Archive" targetRef="EndEvent_Done" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_Calibration">

      <bpmndi:BPMNShape id="Shape_Start" bpmnElement="StartEvent_Submitted">
        <dc:Bounds x="160" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="140" y="235" width="80" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Receive" bpmnElement="Task_Receive">
        <dc:Bounds x="240" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Merge" bpmnElement="Gateway_Merge" isMarkerVisible="true">
        <dc:Bounds x="390" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Check" bpmnElement="Task_Check">
        <dc:Bounds x="490" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Decision" bpmnElement="Gateway_Decision" isMarkerVisible="true">
        <dc:Bounds x="640" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="620" y="155" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Ask" bpmnElement="Task_Ask">
        <dc:Bounds x="615" y="330" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_EventGw" bpmnElement="Gateway_Event">
        <dc:Bounds x="640" y="450" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Msg" bpmnElement="Event_Msg">
        <dc:Bounds x="762" y="457" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="740" y="500" width="80" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Timer" bpmnElement="Event_Timer">
        <dc:Bounds x="542" y="457" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="488" y="468" width="46" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Rejected" bpmnElement="EndEvent_Rejected">
        <dc:Bounds x="542" y="572" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="518" y="615" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Approve" bpmnElement="Task_Approve">
        <dc:Bounds x="740" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Split" bpmnElement="Gateway_Split">
        <dc:Bounds x="890" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Record" bpmnElement="Task_Record">
        <dc:Bounds x="990" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Notify" bpmnElement="Task_Notify">
        <dc:Bounds x="990" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_BadJoin" bpmnElement="Gateway_BadJoin" isMarkerVisible="true">
        <dc:Bounds x="1140" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Pay" bpmnElement="Task_Pay">
        <dc:Bounds x="1240" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Archive" bpmnElement="Task_Archive">
        <dc:Bounds x="1390" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Done" bpmnElement="EndEvent_Done">
        <dc:Bounds x="1540" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1513" y="235" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Edge_Flow_01" bpmnElement="Flow_01">
        <di:waypoint x="196" y="210" /><di:waypoint x="240" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_02" bpmnElement="Flow_02">
        <di:waypoint x="340" y="210" /><di:waypoint x="390" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_03" bpmnElement="Flow_03">
        <di:waypoint x="440" y="210" /><di:waypoint x="490" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_04" bpmnElement="Flow_04">
        <di:waypoint x="590" y="210" /><di:waypoint x="640" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_05" bpmnElement="Flow_05">
        <di:waypoint x="665" y="235" /><di:waypoint x="665" y="330" />
        <bpmndi:BPMNLabel><dc:Bounds x="672" y="255" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_06" bpmnElement="Flow_06">
        <di:waypoint x="665" y="410" /><di:waypoint x="665" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_07" bpmnElement="Flow_07">
        <di:waypoint x="690" y="475" /><di:waypoint x="762" y="475" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_08" bpmnElement="Flow_08">
        <di:waypoint x="780" y="457" />
        <di:waypoint x="780" y="370" />
        <di:waypoint x="415" y="370" />
        <di:waypoint x="415" y="235" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_09" bpmnElement="Flow_09">
        <di:waypoint x="640" y="475" /><di:waypoint x="578" y="475" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_10" bpmnElement="Flow_10">
        <di:waypoint x="560" y="493" /><di:waypoint x="560" y="572" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_11" bpmnElement="Flow_11">
        <di:waypoint x="690" y="210" /><di:waypoint x="740" y="210" />
        <bpmndi:BPMNLabel><dc:Bounds x="700" y="188" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_12" bpmnElement="Flow_12">
        <di:waypoint x="840" y="210" /><di:waypoint x="890" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_13" bpmnElement="Flow_13">
        <di:waypoint x="915" y="185" /><di:waypoint x="915" y="120" /><di:waypoint x="990" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_14" bpmnElement="Flow_14">
        <di:waypoint x="915" y="235" /><di:waypoint x="915" y="300" /><di:waypoint x="990" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_15" bpmnElement="Flow_15">
        <di:waypoint x="1090" y="120" /><di:waypoint x="1165" y="120" /><di:waypoint x="1165" y="185" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_16" bpmnElement="Flow_16">
        <di:waypoint x="1090" y="300" /><di:waypoint x="1165" y="300" /><di:waypoint x="1165" y="235" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_17" bpmnElement="Flow_17">
        <di:waypoint x="1190" y="210" /><di:waypoint x="1240" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_18" bpmnElement="Flow_18">
        <di:waypoint x="1340" y="210" /><di:waypoint x="1390" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_19" bpmnElement="Flow_19">
        <di:waypoint x="1490" y="210" /><di:waypoint x="1540" y="210" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
