<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_DrivingLicense" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Process_DrivingLicense" name="Driving License Renewal / Issuance Process" isExecutable="false">
    <bpmn:startEvent id="StartEvent_ApplicationReceived" name="Application - solemn declaration and supporting documents received (in person or digitally)">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Start" />
    </bpmn:startEvent>
    <bpmn:userTask id="Task_CheckDocuments" name="Check completeness and correctness of supporting documents">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_DocsResubmitted</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Omissions" name="Omissions identified?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_OmissionsYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_OmissionsNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_InformParty" name="Inform interested party of need to provide additional information">
      <bpmn:incoming>Flow_OmissionsYes</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:eventBasedGateway id="Gateway_WaitForResponse" name="Wait for documents or deadline">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDocsSubmitted</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToTimeout</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_DocsSubmitted" name="Requested documents submitted">
      <bpmn:incoming>Flow_ToDocsSubmitted</bpmn:incoming>
      <bpmn:outgoing>Flow_DocsResubmitted</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Docs" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_Timeout15Days" name="15 days passed without submission">
      <bpmn:incoming>Flow_ToTimeout</bpmn:incoming>
      <bpmn:outgoing>Flow_ToTerminate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_15Days">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_Terminated" name="Process terminated">
      <bpmn:incoming>Flow_ToTerminate</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TerminateEventDefinition_1" />
    </bpmn:endEvent>
    <bpmn:userTask id="Task_RegisterApplication" name="Register the application">
      <bpmn:incoming>Flow_OmissionsNo</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_IssueCertificate" name="Give Certificate of Submission of Request to the person concerned">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_LicenseExpired" name="License expired or expires before printing of new form?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_ExpiredYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_ExpiredNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ProvisionalLicense" name="Issue provisional driving license to the person concerned">
      <bpmn:incoming>Flow_ExpiredYes</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Merge">
      <bpmn:incoming>Flow_ExpiredNo</bpmn:incoming>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_IssueLicense" name="Issue driving license via electronic entry in Driving License Register">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Boundary_ReminderTimer" name="Every 5 working days" cancelActivity="false" attachedToRef="Task_IssueLicense">
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_5Days">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P5D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sendTask id="Task_SendReminder" name="Send automated reminder to responsible official">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="EndEvent_ReminderSent" name="Reminder sent">
      <bpmn:incoming>Flow_10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_SendToPassportDirectorate" name="Send electronic information and print application (with photo and signature) to Passport Directorate of Hellenic Police">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Task_DeliverLicense" name="Hand over driving license in person to the person concerned">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Completed" name="Driving license delivered">
      <bpmn:incoming>Flow_12</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_ApplicationReceived" targetRef="Task_CheckDocuments" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CheckDocuments" targetRef="Gateway_Omissions" />
    <bpmn:sequenceFlow id="Flow_OmissionsYes" name="Yes" sourceRef="Gateway_Omissions" targetRef="Task_InformParty" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_InformParty" targetRef="Gateway_WaitForResponse" />
    <bpmn:sequenceFlow id="Flow_ToDocsSubmitted" sourceRef="Gateway_WaitForResponse" targetRef="Event_DocsSubmitted" />
    <bpmn:sequenceFlow id="Flow_ToTimeout" sourceRef="Gateway_WaitForResponse" targetRef="Event_Timeout15Days" />
    <bpmn:sequenceFlow id="Flow_DocsResubmitted" sourceRef="Event_DocsSubmitted" targetRef="Task_CheckDocuments" />
    <bpmn:sequenceFlow id="Flow_ToTerminate" sourceRef="Event_Timeout15Days" targetRef="EndEvent_Terminated" />
    <bpmn:sequenceFlow id="Flow_OmissionsNo" name="No" sourceRef="Gateway_Omissions" targetRef="Task_RegisterApplication" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_RegisterApplication" targetRef="Task_IssueCertificate" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_IssueCertificate" targetRef="Gateway_LicenseExpired" />
    <bpmn:sequenceFlow id="Flow_ExpiredYes" name="Yes" sourceRef="Gateway_LicenseExpired" targetRef="Task_ProvisionalLicense" />
    <bpmn:sequenceFlow id="Flow_ExpiredNo" name="No" sourceRef="Gateway_LicenseExpired" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_ProvisionalLicense" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Gateway_Merge" targetRef="Task_IssueLicense" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_IssueLicense" targetRef="Task_SendToPassportDirectorate" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Boundary_ReminderTimer" targetRef="Task_SendReminder" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_SendReminder" targetRef="EndEvent_ReminderSent" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_SendToPassportDirectorate" targetRef="Task_DeliverLicense" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_DeliverLicense" targetRef="EndEvent_Completed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_DrivingLicense">
