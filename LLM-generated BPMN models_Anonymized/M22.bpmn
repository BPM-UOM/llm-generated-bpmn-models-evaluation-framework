<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_DrivingLicense" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_TCS" name="Transport and Communications Service of the Regional Unit" processRef="Process_DrivingLicense" />
  </bpmn:collaboration>
  <bpmn:process id="Process_DrivingLicense" name="Driving License Application Handling" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Application, solemn declaration and supporting documents received (in person or digitally)">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Start" />
    </bpmn:startEvent>
    <bpmn:task id="Task_Check" name="Check completeness and correctness of supporting documents">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Omissions" name="Omissions identified?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_Inform" name="Inform interested party of the need to provide additional information">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:eventBasedGateway id="Gateway_EventBased" name="Wait for documents or deadline">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_DocsSubmitted" name="Requested documents submitted">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Docs" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_Timeout15d" name="15 days without submission">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_15d">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_Terminated" name="Process terminated">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Register" name="Register the application">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Certificate" name="Give Certificate of Submission of Request to the person concerned">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Expired" name="License expired or expires before printing of new form?">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Provisional" name="Issue provisional driving license to the person concerned">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Merge">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_IssueLicense" name="Issue driving license via electronic entry in the Driving License Register">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:boundaryEvent id="BoundaryEvent_Reminder" name="Every 5 working days (while license not issued)" cancelActivity="false" attachedToRef="Task_IssueLicense">
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_5d">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P5D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="Task_Reminder" name="Send automated reminder to responsible official">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Reminder" name="Reminder sent">
      <bpmn:incoming>Flow_20</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_SendToPolice" name="Send electronic information and print application (photo, signature) to Passport Directorate of the Hellenic Police">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:task id="Task_Receive" name="Person concerned receives driving license in person at the Service">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Completed" name="Driving license delivered">
      <bpmn:incoming>Flow_18</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_Check" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Check" targetRef="Gateway_Omissions" />
    <bpmn:sequenceFlow id="Flow_3" name="Yes" sourceRef="Gateway_Omissions" targetRef="Task_Inform" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Inform" targetRef="Gateway_EventBased" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_EventBased" targetRef="Event_DocsSubmitted" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Event_DocsSubmitted" targetRef="Task_Check" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Gateway_EventBased" targetRef="Event_Timeout15d" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Event_Timeout15d" targetRef="EndEvent_Terminated" />
    <bpmn:sequenceFlow id="Flow_9" name="No" sourceRef="Gateway_Omissions" targetRef="Task_Register" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_Register" targetRef="Task_Certificate" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_Certificate" targetRef="Gateway_Expired" />
    <bpmn:sequenceFlow id="Flow_12" name="Yes" sourceRef="Gateway_Expired" targetRef="Task_Provisional" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_Provisional" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_14" name="No" sourceRef="Gateway_Expired" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Gateway_Merge" targetRef="Task_IssueLicense" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_IssueLicense" targetRef="Task_SendToPolice" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_SendToPolice" targetRef="Task_Receive" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_Receive" targetRef="EndEvent_Completed" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="BoundaryEvent_Reminder" targetRef="Task_Reminder" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="Task_Reminder" targetRef="EndEvent_Reminder" />
  </bpmn:process>
