<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_OrderFulfillment" targetNamespace="http://example.com/bpmn/order-fulfillment" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:message id="Message_RawMaterialOrder_S1" name="Raw material order to Supplier 1" />
  <bpmn:message id="Message_RawMaterialDelivery_S1" name="Raw material delivery from Supplier 1" />
  <bpmn:message id="Message_RawMaterialOrder_S2" name="Raw material order to Supplier 2" />
  <bpmn:message id="Message_RawMaterialDelivery_S2" name="Raw material delivery from Supplier 2" />
  <bpmn:dataStore id="DataStore_WarehouseDB" name="Warehouse Database" />
  <bpmn:dataStore id="DataStore_SuppliersCatalog" name="Suppliers Catalog" />
  <bpmn:collaboration id="Collaboration_OrderFulfillment">
    <bpmn:participant id="Participant_Seller" name="Seller Organization" processRef="Process_OrderFulfillment" />
    <bpmn:participant id="Participant_Supplier1" name="Supplier 1" />
    <bpmn:participant id="Participant_Supplier2" name="Supplier 2" />
    <bpmn:messageFlow id="MessageFlow_Order_S1" name="Raw material order" sourceRef="Task_OrderSupplier1" targetRef="Participant_Supplier1" messageRef="Message_RawMaterialOrder_S1" />
    <bpmn:messageFlow id="MessageFlow_Delivery_S1" name="Raw material delivery" sourceRef="Participant_Supplier1" targetRef="Task_ReceiveSupplier1" messageRef="Message_RawMaterialDelivery_S1" />
    <bpmn:messageFlow id="MessageFlow_Order_S2" name="Raw material order" sourceRef="Task_OrderSupplier2" targetRef="Participant_Supplier2" messageRef="Message_RawMaterialOrder_S2" />
    <bpmn:messageFlow id="MessageFlow_Delivery_S2" name="Raw material delivery" sourceRef="Participant_Supplier2" targetRef="Task_ReceiveSupplier2" messageRef="Message_RawMaterialDelivery_S2" />
  </bpmn:collaboration>
  <bpmn:process id="Process_OrderFulfillment" name="Order Fulfillment" isExecutable="false">
    <bpmn:laneSet id="LaneSet_SellerDepartments">
      <bpmn:lane id="Lane_WarehouseDistribution" name="Warehouse &#38; Distribution Department">
        <bpmn:flowNodeRef>StartEvent_PurchaseOrderReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ProductInStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetrieveProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckRawMaterials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SelectSuppliers</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceiveSupplier1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceiveSupplier2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MaterialsObtained</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManufactureProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ProductReady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipProduct</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Sales" name="Sales Department">
        <bpmn:flowNodeRef>Task_ConfirmOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AfterConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IssueInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_WaitPayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AfterPaymentAndShipping</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArchiveOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_OrderArchived</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_PurchaseOrderReceived" name="Purchase order received">
      <bpmn:outgoing>Flow_Start_CheckStock</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CheckStock" name="Check product stock in ERP">
      <bpmn:incoming>Flow_Start_CheckStock</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckStock_StockGateway</bpmn:outgoing>
      <bpmn:property id="Property_CheckStockInput" name="Warehouse stock data" />
      <bpmn:property id="Property_03ngazd" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_WarehouseDB">
        <bpmn:sourceRef>DataStoreReference_WarehouseDB</bpmn:sourceRef>
        <bpmn:targetRef>Property_03ngazd</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_ProductInStock" name="Product in stock?" default="Flow_NotInStock">
      <bpmn:incoming>Flow_CheckStock_StockGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_InStock</bpmn:outgoing>
      <bpmn:outgoing>Flow_NotInStock</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="Task_RetrieveProduct" name="Retrieve product from warehouse">
      <bpmn:incoming>Flow_InStock</bpmn:incoming>
      <bpmn:outgoing>Flow_Retrieve_ProductReady</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:serviceTask id="Task_CheckRawMaterials" name="Check raw material availability in ERP">
      <bpmn:incoming>Flow_NotInStock</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckMaterials_SelectSuppliers</bpmn:outgoing>
      <bpmn:property id="Property_CheckMaterialsInput" name="Supplier catalog data" />
      <bpmn:property id="Property_193ovea" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_SuppliersCatalog">
        <bpmn:sourceRef>DataStoreReference_SuppliersCatalog</bpmn:sourceRef>
        <bpmn:targetRef>Property_193ovea</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:serviceTask>
    <bpmn:inclusiveGateway id="Gateway_SelectSuppliers" name="Which suppliers are required?">
      <bpmn:incoming>Flow_CheckMaterials_SelectSuppliers</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSupplier1</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToSupplier2</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:sendTask id="Task_OrderSupplier1" name="Order raw materials from Supplier 1" messageRef="Message_RawMaterialOrder_S1">
      <bpmn:incoming>Flow_ToSupplier1</bpmn:incoming>
      <bpmn:outgoing>Flow_OrderS1_ReceiveS1</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Task_ReceiveSupplier1" name="Receive raw materials from Supplier 1" messageRef="Message_RawMaterialDelivery_S1">
      <bpmn:incoming>Flow_OrderS1_ReceiveS1</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveS1_MaterialsJoin</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:sendTask id="Task_OrderSupplier2" name="Order raw materials from Supplier 2" messageRef="Message_RawMaterialOrder_S2">
      <bpmn:incoming>Flow_ToSupplier2</bpmn:incoming>
      <bpmn:outgoing>Flow_OrderS2_ReceiveS2</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Task_ReceiveSupplier2" name="Receive raw materials from Supplier 2" messageRef="Message_RawMaterialDelivery_S2">
      <bpmn:incoming>Flow_OrderS2_ReceiveS2</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveS2_MaterialsJoin</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:inclusiveGateway id="Gateway_MaterialsObtained" name="Required raw materials obtained">
      <bpmn:incoming>Flow_ReceiveS1_MaterialsJoin</bpmn:incoming>
      <bpmn:incoming>Flow_ReceiveS2_MaterialsJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_MaterialsJoin_Manufacture</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:manualTask id="Task_ManufactureProduct" name="Manufacture product">
      <bpmn:incoming>Flow_MaterialsJoin_Manufacture</bpmn:incoming>
      <bpmn:outgoing>Flow_Manufacture_ProductReady</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:exclusiveGateway id="Gateway_ProductReady" name="Product ready">
      <bpmn:incoming>Flow_Retrieve_ProductReady</bpmn:incoming>
      <bpmn:incoming>Flow_Manufacture_ProductReady</bpmn:incoming>
      <bpmn:outgoing>Flow_ProductReady_ConfirmOrder</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ConfirmOrder" name="Confirm order">
      <bpmn:incoming>Flow_ProductReady_ConfirmOrder</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirm_ParallelSplit</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_AfterConfirmation" name="Invoice and ship in parallel">
      <bpmn:incoming>Flow_Confirm_ParallelSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_Parallel_ToInvoice</bpmn:outgoing>
      <bpmn:outgoing>Flow_Parallel_ToShip</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_IssueInvoice" name="Issue invoice">
      <bpmn:incoming>Flow_Parallel_ToInvoice</bpmn:incoming>
      <bpmn:outgoing>Flow_Invoice_WaitPayment</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="Event_WaitPayment" name="Payment received">
      <bpmn:incoming>Flow_Invoice_WaitPayment</bpmn:incoming>
      <bpmn:outgoing>Flow_Payment_ParallelJoin</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Payment" />
    </bpmn:intermediateCatchEvent>
    <bpmn:manualTask id="Task_ShipProduct" name="Ship product">
      <bpmn:incoming>Flow_Parallel_ToShip</bpmn:incoming>
      <bpmn:outgoing>Flow_Ship_ParallelJoin</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:parallelGateway id="Gateway_AfterPaymentAndShipping" name="Payment received and product shipped">
      <bpmn:incoming>Flow_Payment_ParallelJoin</bpmn:incoming>
      <bpmn:incoming>Flow_Ship_ParallelJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_ParallelJoin_Archive</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_ArchiveOrder" name="Archive order">
      <bpmn:incoming>Flow_ParallelJoin_Archive</bpmn:incoming>
      <bpmn:outgoing>Flow_Archive_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_OrderArchived" name="Order archived">
      <bpmn:incoming>Flow_Archive_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataStoreReference id="DataStoreReference_WarehouseDB" name="Warehouse Database" dataStoreRef="DataStore_WarehouseDB" />
    <bpmn:dataStoreReference id="DataStoreReference_SuppliersCatalog" name="Suppliers Catalog" dataStoreRef="DataStore_SuppliersCatalog" />
    <bpmn:sequenceFlow id="Flow_Start_CheckStock" sourceRef="StartEvent_PurchaseOrderReceived" targetRef="Task_CheckStock" />
    <bpmn:sequenceFlow id="Flow_CheckStock_StockGateway" sourceRef="Task_CheckStock" targetRef="Gateway_ProductInStock" />
    <bpmn:sequenceFlow id="Flow_InStock" name="Yes" sourceRef="Gateway_ProductInStock" targetRef="Task_RetrieveProduct">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">productInStock = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NotInStock" name="No" sourceRef="Gateway_ProductInStock" targetRef="Task_CheckRawMaterials">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">productInStock = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Retrieve_ProductReady" sourceRef="Task_RetrieveProduct" targetRef="Gateway_ProductReady" />
    <bpmn:sequenceFlow id="Flow_CheckMaterials_SelectSuppliers" sourceRef="Task_CheckRawMaterials" targetRef="Gateway_SelectSuppliers" />
    <bpmn:sequenceFlow id="Flow_ToSupplier1" name="Supplier 1 required" sourceRef="Gateway_SelectSuppliers" targetRef="Task_OrderSupplier1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">requiresSupplier1 = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ToSupplier2" name="Supplier 2 required" sourceRef="Gateway_SelectSuppliers" targetRef="Task_OrderSupplier2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">requiresSupplier2 = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_OrderS1_ReceiveS1" sourceRef="Task_OrderSupplier1" targetRef="Task_ReceiveSupplier1" />
    <bpmn:sequenceFlow id="Flow_ReceiveS1_MaterialsJoin" sourceRef="Task_ReceiveSupplier1" targetRef="Gateway_MaterialsObtained" />
    <bpmn:sequenceFlow id="Flow_OrderS2_ReceiveS2" sourceRef="Task_OrderSupplier2" targetRef="Task_ReceiveSupplier2" />
    <bpmn:sequenceFlow id="Flow_ReceiveS2_MaterialsJoin" sourceRef="Task_ReceiveSupplier2" targetRef="Gateway_MaterialsObtained" />
    <bpmn:sequenceFlow id="Flow_MaterialsJoin_Manufacture" sourceRef="Gateway_MaterialsObtained" targetRef="Task_ManufactureProduct" />
    <bpmn:sequenceFlow id="Flow_Manufacture_ProductReady" sourceRef="Task_ManufactureProduct" targetRef="Gateway_ProductReady" />
    <bpmn:sequenceFlow id="Flow_ProductReady_ConfirmOrder" sourceRef="Gateway_ProductReady" targetRef="Task_ConfirmOrder" />
    <bpmn:sequenceFlow id="Flow_Confirm_ParallelSplit" sourceRef="Task_ConfirmOrder" targetRef="Gateway_AfterConfirmation" />
    <bpmn:sequenceFlow id="Flow_Parallel_ToInvoice" sourceRef="Gateway_AfterConfirmation" targetRef="Task_IssueInvoice" />
    <bpmn:sequenceFlow id="Flow_Parallel_ToShip" sourceRef="Gateway_AfterConfirmation" targetRef="Task_ShipProduct" />
    <bpmn:sequenceFlow id="Flow_Invoice_WaitPayment" sourceRef="Task_IssueInvoice" targetRef="Event_WaitPayment" />
    <bpmn:sequenceFlow id="Flow_Payment_ParallelJoin" sourceRef="Event_WaitPayment" targetRef="Gateway_AfterPaymentAndShipping" />
    <bpmn:sequenceFlow id="Flow_Ship_ParallelJoin" sourceRef="Task_ShipProduct" targetRef="Gateway_AfterPaymentAndShipping" />
    <bpmn:sequenceFlow id="Flow_ParallelJoin_Archive" sourceRef="Gateway_AfterPaymentAndShipping" targetRef="Task_ArchiveOrder" />
    <bpmn:sequenceFlow id="Flow_Archive_End" sourceRef="Task_ArchiveOrder" targetRef="EndEvent_OrderArchived" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_OrderFulfillment">
    <bpmndi:BPMNPlane id="BPMNPlane_OrderFulfillment" bpmnElement="Collaboration_OrderFulfillment">
      <bpmndi:BPMNShape id="Shape_Participant_Seller" bpmnElement="Participant_Seller" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="2460" height="620" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Warehouse" bpmnElement="Lane_WarehouseDistribution" isHorizontal="true">
        <dc:Bounds x="190" y="330" width="2430" height="370" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Sales" bpmnElement="Lane_Sales" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="2430" height="250" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_StartEvent" bpmnElement="StartEvent_PurchaseOrderReceived">
        <dc:Bounds x="230" y="430" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="212" y="470" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_CheckStock" bpmnElement="Task_CheckStock">
        <dc:Bounds x="320" y="405" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_StockGateway" bpmnElement="Gateway_ProductInStock" isMarkerVisible="true">
        <dc:Bounds x="510" y="420" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="493" y="385" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Retrieve" bpmnElement="Task_RetrieveProduct">
        <dc:Bounds x="630" y="355" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_CheckMaterials" bpmnElement="Task_CheckRawMaterials">
        <dc:Bounds x="630" y="500" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_SelectSuppliers" bpmnElement="Gateway_SelectSuppliers">
        <dc:Bounds x="840" y="515" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="817" y="575" width="97" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_OrderS1" bpmnElement="Task_OrderSupplier1">
        <dc:Bounds x="960" y="455" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ReceiveS1" bpmnElement="Task_ReceiveSupplier1">
        <dc:Bounds x="1170" y="455" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_OrderS2" bpmnElement="Task_OrderSupplier2">
        <dc:Bounds x="960" y="590" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ReceiveS2" bpmnElement="Task_ReceiveSupplier2">
        <dc:Bounds x="1170" y="590" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_MaterialsJoin" bpmnElement="Gateway_MaterialsObtained">
        <dc:Bounds x="1380" y="515" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1348" y="575" width="114" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Manufacture" bpmnElement="Task_ManufactureProduct">
        <dc:Bounds x="1490" y="500" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ProductReady" bpmnElement="Gateway_ProductReady" isMarkerVisible="true">
        <dc:Bounds x="1690" y="380" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1681" y="345" width="69" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ConfirmOrder" bpmnElement="Task_ConfirmOrder">
        <dc:Bounds x="1790" y="170" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ParallelSplit" bpmnElement="Gateway_AfterConfirmation">
        <dc:Bounds x="1970" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1949" y="140" width="92" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_IssueInvoice" bpmnElement="Task_IssueInvoice">
        <dc:Bounds x="2070" y="105" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_WaitPayment" bpmnElement="Event_WaitPayment">
        <dc:Bounds x="2240" y="127" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2216" y="92" width="89" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ShipProduct" bpmnElement="Task_ShipProduct">
        <dc:Bounds x="2070" y="390" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ParallelJoin" bpmnElement="Gateway_AfterPaymentAndShipping">
        <dc:Bounds x="2320" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2290" y="240" width="110" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ArchiveOrder" bpmnElement="Task_ArchiveOrder">
        <dc:Bounds x="2420" y="170" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent" bpmnElement="EndEvent_OrderArchived">
        <dc:Bounds x="2570" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2554" y="235" width="73" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_WarehouseDB" bpmnElement="DataStoreReference_WarehouseDB">
        <dc:Bounds x="340" y="565" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="312" y="620" width="106" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_SuppliersCatalog" bpmnElement="DataStoreReference_SuppliersCatalog">
        <dc:Bounds x="690" y="610" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="672" y="665" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Start_CheckStock" bpmnElement="Flow_Start_CheckStock">
        <di:waypoint x="266" y="448" />
        <di:waypoint x="320" y="445" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_CheckStock_Gateway" bpmnElement="Flow_CheckStock_StockGateway">
        <di:waypoint x="450" y="445" />
        <di:waypoint x="510" y="445" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_InStock" bpmnElement="Flow_InStock">
        <di:waypoint x="535" y="420" />
        <di:waypoint x="535" y="395" />
        <di:waypoint x="630" y="395" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="566" y="370" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_NotInStock" bpmnElement="Flow_NotInStock">
        <di:waypoint x="535" y="470" />
        <di:waypoint x="535" y="540" />
        <di:waypoint x="630" y="540" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="568" y="515" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Retrieve_ProductReady" bpmnElement="Flow_Retrieve_ProductReady">
        <di:waypoint x="770" y="395" />
        <di:waypoint x="1690" y="405" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_CheckMaterials_Select" bpmnElement="Flow_CheckMaterials_SelectSuppliers">
        <di:waypoint x="780" y="540" />
        <di:waypoint x="840" y="540" />
      </bpmndi:BPMNEdge>
