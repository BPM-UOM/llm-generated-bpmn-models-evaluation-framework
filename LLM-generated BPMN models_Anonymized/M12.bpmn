<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Claim Handling Process" processRef="Process_1" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Claim Registered">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_ExamineClaim" name="Examine Claim">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_WriteRecommendation" name="Write Settlement Recommendation">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:incoming>Flow_NotOk</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CheckRecommendation" name="Check Recommendation">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Ok" name="Is OK?">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Ok</bpmn:outgoing>
      <bpmn:outgoing>Flow_NotOk</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_1" name="Proceed with Handling">
      <bpmn:incoming>Flow_Ok</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_ExamineClaim" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ExamineClaim" targetRef="Task_WriteRecommendation" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_WriteRecommendation" targetRef="Task_CheckRecommendation" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_CheckRecommendation" targetRef="Gateway_Ok" />
    <bpmn:sequenceFlow id="Flow_Ok" name="OK" sourceRef="Gateway_Ok" targetRef="EndEvent_1" />
    <bpmn:sequenceFlow id="Flow_NotOk" name="Not OK" sourceRef="Gateway_Ok" targetRef="Task_WriteRecommendation" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_1_di" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="120" y="80" width="850" height="250" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="190" y="172" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ExamineClaim_di" bpmnElement="Task_ExamineClaim">
        <dc:Bounds x="270" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_WriteRecommendation_di" bpmnElement="Task_WriteRecommendation">
        <dc:Bounds x="420" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckRecommendation_di" bpmnElement="Task_CheckRecommendation">
        <dc:Bounds x="570" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Ok_di" bpmnElement="Gateway_Ok" isMarkerVisible="true">
        <dc:Bounds x="725" y="165" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="852" y="172" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="226" y="190" />
        <di:waypoint x="270" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="370" y="190" />
        <di:waypoint x="420" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="520" y="190" />
        <di:waypoint x="570" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="670" y="190" />
        <di:waypoint x="725" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Ok_di" bpmnElement="Flow_Ok">
        <di:waypoint x="775" y="190" />
        <di:waypoint x="852" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotOk_di" bpmnElement="Flow_NotOk">
        <di:waypoint x="750" y="165" />
        <di:waypoint x="750" y="110" />
        <di:waypoint x="470" y="110" />
        <di:waypoint x="470" y="150" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
