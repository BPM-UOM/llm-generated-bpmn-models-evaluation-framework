<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_OrderFulfillment" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Seller" name="Seller" processRef="Process_OrderFulfillment" />
  </bpmn:collaboration>
  <bpmn:process id="Process_OrderFulfillment" name="Order Fulfillment" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Sales" name="Sales">
        <bpmn:flowNodeRef>Task_ConfirmOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AndSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceivePayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AndJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArchiveOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_OrderFulfilled</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Warehouse" name="Warehouse &#38; Distribution">
        <bpmn:flowNodeRef>StartEvent_POReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_InStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckRawMaterials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_OrSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_OrJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManufactureProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetrieveProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_XorJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipProduct</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_POReceived" name="Purchase order received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CheckStock" name="Check stock availability">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_InStock" name="Product in stock?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_CheckRawMaterials" name="Check raw materials availability">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:inclusiveGateway id="Gateway_OrSplit" name="Raw materials required">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:task id="Task_OrderSupplier1" name="Order raw materials from Supplier 1">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_OrderSupplier2" name="Order raw materials from Supplier 2">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:inclusiveGateway id="Gateway_OrJoin">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:task id="Task_ManufactureProduct" name="Manufacture product">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RetrieveProduct" name="Retrieve product from warehouse">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_XorJoin">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ConfirmOrder" name="Confirm order">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_AndSplit">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_EmitInvoice" name="Emit invoice">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:receiveTask id="Task_ReceivePayment" name="Receive payment">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:task id="Task_ShipProduct" name="Ship product">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_AndJoin">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_ArchiveOrder" name="Archive order">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_OrderFulfilled" name="Order fulfilled">
      <bpmn:incoming>Flow_21</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_POReceived" targetRef="Task_CheckStock" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CheckStock" targetRef="Gateway_InStock" />
    <bpmn:sequenceFlow id="Flow_3" name="No" sourceRef="Gateway_InStock" targetRef="Task_CheckRawMaterials" />
    <bpmn:sequenceFlow id="Flow_4" name="Yes" sourceRef="Gateway_InStock" targetRef="Task_RetrieveProduct" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_CheckRawMaterials" targetRef="Gateway_OrSplit" />
    <bpmn:sequenceFlow id="Flow_6" name="Material from Supplier 1 needed" sourceRef="Gateway_OrSplit" targetRef="Task_OrderSupplier1" />
    <bpmn:sequenceFlow id="Flow_7" name="Material from Supplier 2 needed" sourceRef="Gateway_OrSplit" targetRef="Task_OrderSupplier2" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_OrderSupplier1" targetRef="Gateway_OrJoin" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_OrderSupplier2" targetRef="Gateway_OrJoin" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Gateway_OrJoin" targetRef="Task_ManufactureProduct" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_ManufactureProduct" targetRef="Gateway_XorJoin" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_RetrieveProduct" targetRef="Gateway_XorJoin" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Gateway_XorJoin" targetRef="Task_ConfirmOrder" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_ConfirmOrder" targetRef="Gateway_AndSplit" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Gateway_AndSplit" targetRef="Task_EmitInvoice" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Gateway_AndSplit" targetRef="Task_ShipProduct" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_EmitInvoice" targetRef="Task_ReceivePayment" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_ReceivePayment" targetRef="Gateway_AndJoin" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="Task_ShipProduct" targetRef="Gateway_AndJoin" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="Gateway_AndJoin" targetRef="Task_ArchiveOrder" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="Task_ArchiveOrder" targetRef="EndEvent_OrderFulfilled" />
  </bpmn:process>
