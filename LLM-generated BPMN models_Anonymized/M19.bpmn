<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_ClaimHandling" targetNamespace="http://example.com/bpmn/claim-handling" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Process_ClaimHandling" name="Claim Handling Process" isExecutable="false">
    <bpmn:startEvent id="StartEvent_ClaimRegistered" name="Claim registered">
      <bpmn:outgoing>Flow_Start_Examine</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_ExamineClaim" name="Examine claim">
      <bpmn:incoming>Flow_Start_Examine</bpmn:incoming>
      <bpmn:outgoing>Flow_Examine_Recommend</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_WriteRecommendation" name="Write settlement recommendation">
      <bpmn:incoming>Flow_Examine_Recommend</bpmn:incoming>
      <bpmn:incoming>Flow_NotOK_Rewrite</bpmn:incoming>
      <bpmn:outgoing>Flow_Recommend_Check</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_CheckRecommendation" name="Check settlement recommendation">
      <bpmn:incoming>Flow_Recommend_Check</bpmn:incoming>
      <bpmn:outgoing>Flow_Check_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ClaimOK" name="Claim OK?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_Check_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_OK_Proceed</bpmn:outgoing>
      <bpmn:outgoing>Flow_NotOK_Rewrite</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ProceedClaimHandling" name="Proceed with claim handling">
      <bpmn:incoming>Flow_OK_Proceed</bpmn:incoming>
      <bpmn:outgoing>Flow_Proceed_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_ClaimHandlingContinues" name="Claim handling proceeds">
      <bpmn:incoming>Flow_Proceed_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Examine" sourceRef="StartEvent_ClaimRegistered" targetRef="Task_ExamineClaim" />
    <bpmn:sequenceFlow id="Flow_Examine_Recommend" sourceRef="Task_ExamineClaim" targetRef="Task_WriteRecommendation" />
    <bpmn:sequenceFlow id="Flow_Recommend_Check" sourceRef="Task_WriteRecommendation" targetRef="Task_CheckRecommendation" />
    <bpmn:sequenceFlow id="Flow_Check_Gateway" sourceRef="Task_CheckRecommendation" targetRef="Gateway_ClaimOK" />
    <bpmn:sequenceFlow id="Flow_OK_Proceed" name="OK" sourceRef="Gateway_ClaimOK" targetRef="Task_ProceedClaimHandling" />
    <bpmn:sequenceFlow id="Flow_NotOK_Rewrite" name="Not OK" sourceRef="Gateway_ClaimOK" targetRef="Task_WriteRecommendation" />
    <bpmn:sequenceFlow id="Flow_Proceed_End" sourceRef="Task_ProceedClaimHandling" targetRef="EndEvent_ClaimHandlingContinues" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_ClaimHandling">
    <bpmndi:BPMNPlane id="BPMNPlane_ClaimHandling" bpmnElement="Process_ClaimHandling">
      <bpmndi:BPMNShape id="Shape_StartEvent" bpmnElement="StartEvent_ClaimRegistered">
        <dc:Bounds x="180" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="158" y="145" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ExamineClaim" bpmnElement="Task_ExamineClaim">
        <dc:Bounds x="270" y="80" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_WriteRecommendation" bpmnElement="Task_WriteRecommendation">
        <dc:Bounds x="440" y="80" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_CheckRecommendation" bpmnElement="Task_CheckRecommendation">
        <dc:Bounds x="650" y="80" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GatewayClaimOK" bpmnElement="Gateway_ClaimOK" isMarkerVisible="true">
        <dc:Bounds x="860" y="95" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="858" y="152" width="54" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ProceedClaimHandling" bpmnElement="Task_ProceedClaimHandling">
        <dc:Bounds x="970" y="80" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent" bpmnElement="EndEvent_ClaimHandlingContinues">
        <dc:Bounds x="1170" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1152" y="145" width="73" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_Examine" bpmnElement="Flow_Start_Examine">
        <di:waypoint x="216" y="120" />
        <di:waypoint x="270" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Examine_Recommend" bpmnElement="Flow_Examine_Recommend">
        <di:waypoint x="390" y="120" />
        <di:waypoint x="440" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Recommend_Check" bpmnElement="Flow_Recommend_Check">
        <di:waypoint x="600" y="120" />
        <di:waypoint x="650" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Check_Gateway" bpmnElement="Flow_Check_Gateway">
        <di:waypoint x="810" y="120" />
        <di:waypoint x="860" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_OK_Proceed" bpmnElement="Flow_OK_Proceed">
        <di:waypoint x="910" y="120" />
        <di:waypoint x="970" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="933" y="102" width="16" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_NotOK_Rewrite" bpmnElement="Flow_NotOK_Rewrite">
        <di:waypoint x="885" y="145" />
        <di:waypoint x="885" y="220" />
        <di:waypoint x="520" y="220" />
        <di:waypoint x="520" y="160" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="693" y="202" width="37" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Proceed_End" bpmnElement="Flow_Proceed_End">
        <di:waypoint x="1120" y="120" />
        <di:waypoint x="1170" y="120" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
