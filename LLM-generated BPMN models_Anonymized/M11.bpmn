<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_OrderFulfillment" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_0">
    <bpmn:participant id="Participant_Seller" name="Seller Organization" processRef="Process_OrderFulfillment" />
  </bpmn:collaboration>
  <bpmn:process id="Process_OrderFulfillment" isExecutable="true">
    <bpmn:laneSet id="LaneSet_0">
      <bpmn:lane id="Lane_WD" name="Warehouse &#38; Distribution Department">
        <bpmn:flowNodeRef>StartEvent_0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_StockSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetrieveProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckMaterials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SuppliersSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSup1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSup2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SuppliersJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manufacture</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_StockJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipProduct</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Sales" name="Sales Department">
        <bpmn:flowNodeRef>Task_ConfirmOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_WaitPayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArchiveOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_0</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_0" name="Purchase Order Received" />
    <bpmn:task id="Task_CheckStock" name="Check Stock against Purchase Order" />
    <bpmn:exclusiveGateway id="Gateway_StockSplit" name="Is product in stock?" />
    <bpmn:task id="Task_RetrieveProduct" name="Retrieve Product from Warehouse" />
    <bpmn:task id="Task_CheckMaterials" name="Check Raw Materials Availability" />
    <bpmn:inclusiveGateway id="Gateway_SuppliersSplit" name="Select Suppliers" />
    <bpmn:task id="Task_OrderSup1" name="Order Raw Materials from Supplier 1" />
    <bpmn:task id="Task_OrderSup2" name="Order Raw Materials from Supplier 2" />
    <bpmn:inclusiveGateway id="Gateway_SuppliersJoin" />
    <bpmn:task id="Task_Manufacture" name="Manufacture Product" />
    <bpmn:exclusiveGateway id="Gateway_StockJoin" />
    <bpmn:task id="Task_ShipProduct" name="Ship Product" />
    <bpmn:task id="Task_ConfirmOrder" name="Confirm Order" />
    <bpmn:parallelGateway id="Gateway_ParallelSplit" />
    <bpmn:task id="Task_EmitInvoice" name="Emit Invoice" />
    <bpmn:task id="Task_WaitPayment" name="Wait for Payment" />
    <bpmn:parallelGateway id="Gateway_ParallelJoin" />
    <bpmn:task id="Task_ArchiveOrder" name="Archive Order" />
    <bpmn:endEvent id="EndEvent_0" name="Order Fulfilled" />
    <bpmn:sequenceFlow id="Flow_1" name="Purchase Order" sourceRef="StartEvent_0" targetRef="Task_CheckStock" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CheckStock" targetRef="Gateway_StockSplit" />
    <bpmn:sequenceFlow id="Flow_3" name="Yes (In Stock)" sourceRef="Gateway_StockSplit" targetRef="Task_RetrieveProduct" />
    <bpmn:sequenceFlow id="Flow_4" name="No (Out of Stock)" sourceRef="Gateway_StockSplit" targetRef="Task_CheckMaterials" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_RetrieveProduct" targetRef="Gateway_StockJoin" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_CheckMaterials" targetRef="Gateway_SuppliersSplit" />
    <bpmn:sequenceFlow id="Flow_7" name="Supplier 1 needed" sourceRef="Gateway_SuppliersSplit" targetRef="Task_OrderSup1" />
    <bpmn:sequenceFlow id="Flow_8" name="Supplier 2 needed" sourceRef="Gateway_SuppliersSplit" targetRef="Task_OrderSup2" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_OrderSup1" targetRef="Gateway_SuppliersJoin" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_OrderSup2" targetRef="Gateway_SuppliersJoin" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Gateway_SuppliersJoin" targetRef="Task_Manufacture" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_Manufacture" targetRef="Gateway_StockJoin" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Gateway_StockJoin" targetRef="Task_ConfirmOrder" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Gateway_ParallelSplit" targetRef="Task_ShipProduct" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="Task_ShipProduct" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_ConfirmOrder" targetRef="Gateway_ParallelSplit" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Gateway_ParallelSplit" targetRef="Task_EmitInvoice" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_EmitInvoice" targetRef="Task_WaitPayment" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_WaitPayment" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="Gateway_ParallelJoin" targetRef="Task_ArchiveOrder" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="Task_ArchiveOrder" targetRef="EndEvent_0" />
  </bpmn:process>
