<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_DrivingLicense" targetNamespace="https://example.org/bpmn/driving-license" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:message id="Message_Application" name="Application, solemn declaration and supporting documents" />
  <bpmn:message id="Message_AdditionalInfoRequest" name="Request for additional information" />
  <bpmn:message id="Message_AdditionalDocuments" name="Requested supporting documents" />
  <bpmn:message id="Message_SubmissionCertificate" name="Certificate of Submission of Request" />
  <bpmn:message id="Message_ProvisionalLicense" name="Provisional driving license" />
  <bpmn:message id="Message_PrintPackage" name="Electronic information and print application" />
  <bpmn:message id="Message_DrivingLicense" name="Driving license" />
  <bpmn:collaboration id="Collaboration_DrivingLicense">
    <bpmn:participant id="Participant_InterestedParty" name="Interested Party" />
    <bpmn:participant id="Participant_Service" name="Transport and Communications Service of the Regional Unit" processRef="Process_DrivingLicense" />
    <bpmn:participant id="Participant_PassportDirectorate" name="Passport Directorate of the Hellenic Police" />
    <bpmn:messageFlow id="MessageFlow_Application" name="Submit application and supporting documents" sourceRef="Participant_InterestedParty" targetRef="StartEvent_ApplicationReceived" messageRef="Message_Application" />
    <bpmn:messageFlow id="MessageFlow_AdditionalInfoRequest" name="Request additional information" sourceRef="Task_InformInterestedParty" targetRef="Participant_InterestedParty" messageRef="Message_AdditionalInfoRequest" />
    <bpmn:messageFlow id="MessageFlow_AdditionalDocuments" name="Submit requested documents" sourceRef="Participant_InterestedParty" targetRef="CatchEvent_DocumentsReceived" messageRef="Message_AdditionalDocuments" />
    <bpmn:messageFlow id="MessageFlow_Certificate" name="Provide submission certificate" sourceRef="Task_ProvideCertificate" targetRef="Participant_InterestedParty" messageRef="Message_SubmissionCertificate" />
    <bpmn:messageFlow id="MessageFlow_ProvisionalLicense" name="Provide provisional driving license" sourceRef="Task_IssueProvisionalLicense" targetRef="Participant_InterestedParty" messageRef="Message_ProvisionalLicense" />
    <bpmn:messageFlow id="MessageFlow_PrintPackage" name="Send electronic information and print application" sourceRef="Task_SendToPassportDirectorate" targetRef="Participant_PassportDirectorate" messageRef="Message_PrintPackage" />
    <bpmn:messageFlow id="MessageFlow_DrivingLicense" name="Deliver driving license in person" sourceRef="Task_HandOverDrivingLicense" targetRef="Participant_InterestedParty" messageRef="Message_DrivingLicense" />
  </bpmn:collaboration>
  <bpmn:process id="Process_DrivingLicense" name="Driving License Application and Issuance" isExecutable="false">
    <bpmn:documentation>
      The process accepts applications submitted directly to the Service or digitally via the designated link.
      The repeating reminder timer is modeled as every five days; implementation must apply the competent authority's
      working-day calendar so that weekends and official holidays are excluded.
    </bpmn:documentation>
    <bpmn:laneSet id="LaneSet_Service">
      <bpmn:lane id="Lane_AutomatedSystem" name="Automated System">
        <bpmn:flowNodeRef>Task_SendAutomatedReminder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ReminderSent</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Official" name="Responsible Official">
        <bpmn:flowNodeRef>StartEvent_ApplicationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckDocuments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_OmissionsIdentified</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InformInterestedParty</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_WaitForDocumentsOrDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEvent_DocumentsReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEvent_FifteenDaysElapsed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_NoDocuments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegisterApplication</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ProvideCertificate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ProvisionalRequired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IssueProvisionalLicense</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ProvisionalMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IssueDrivingLicense</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendToPassportDirectorate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HandOverDrivingLicense</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_LicenseDelivered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_ReminderTimer</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_ApplicationReceived" name="Application and supporting documents received">
      <bpmn:outgoing>Flow_Start_Check</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Application" messageRef="Message_Application" />
    </bpmn:startEvent>
    <bpmn:userTask id="Task_CheckDocuments" name="Check completeness and correctness of supporting documents">
      <bpmn:incoming>Flow_Start_Check</bpmn:incoming>
      <bpmn:incoming>Flow_DocumentsReceived_Recheck</bpmn:incoming>
      <bpmn:outgoing>Flow_Check_Omissions</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_OmissionsIdentified" name="Omissions identified?" default="Flow_NoOmissions_Register">
      <bpmn:incoming>Flow_Check_Omissions</bpmn:incoming>
      <bpmn:outgoing>Flow_Omissions_Inform</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoOmissions_Register</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_InformInterestedParty" name="Inform interested party that additional information is required">
      <bpmn:incoming>Flow_Omissions_Inform</bpmn:incoming>
      <bpmn:outgoing>Flow_Inform_Wait</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:eventBasedGateway id="Gateway_WaitForDocumentsOrDeadline" name="Documents received within 15 days?">
      <bpmn:incoming>Flow_Inform_Wait</bpmn:incoming>
      <bpmn:outgoing>Flow_Wait_Documents</bpmn:outgoing>
      <bpmn:outgoing>Flow_Wait_Timeout</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="CatchEvent_DocumentsReceived" name="Requested documents received">
      <bpmn:incoming>Flow_Wait_Documents</bpmn:incoming>
      <bpmn:outgoing>Flow_DocumentsReceived_Recheck</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_AdditionalDocuments" messageRef="Message_AdditionalDocuments" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="CatchEvent_FifteenDaysElapsed" name="15 days elapsed without submission">
      <bpmn:incoming>Flow_Wait_Timeout</bpmn:incoming>
      <bpmn:outgoing>Flow_Timeout_End</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_FifteenDays">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_NoDocuments" name="Process terminated — documents not received">
      <bpmn:incoming>Flow_Timeout_End</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TerminateEventDefinition_NoDocuments" />
    </bpmn:endEvent>
    <bpmn:userTask id="Task_RegisterApplication" name="Register application">
      <bpmn:incoming>Flow_NoOmissions_Register</bpmn:incoming>
      <bpmn:outgoing>Flow_Register_Certificate</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ProvideCertificate" name="Give Certificate of Submission of Request">
      <bpmn:incoming>Flow_Register_Certificate</bpmn:incoming>
      <bpmn:outgoing>Flow_Certificate_ProvisionalDecision</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ProvisionalRequired" name="License expired or will expire before new form is printed?" default="Flow_NoProvisional_Merge">
      <bpmn:incoming>Flow_Certificate_ProvisionalDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_Provisional_Issue</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoProvisional_Merge</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_IssueProvisionalLicense" name="Issue provisional driving license">
      <bpmn:incoming>Flow_Provisional_Issue</bpmn:incoming>
      <bpmn:outgoing>Flow_Provisional_Merge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ProvisionalMerge" name="Continue issuance">
      <bpmn:incoming>Flow_Provisional_Merge</bpmn:incoming>
      <bpmn:incoming>Flow_NoProvisional_Merge</bpmn:incoming>
      <bpmn:outgoing>Flow_Merge_IssueLicense</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_IssueDrivingLicense" name="Issue driving license by electronic entry in the Driving License Register">
      <bpmn:incoming>Flow_Merge_IssueLicense</bpmn:incoming>
      <bpmn:outgoing>Flow_IssueLicense_SendPassport</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_SendAutomatedReminder" name="Send automated reminder to responsible official">
      <bpmn:incoming>Flow_ReminderTimer_SendReminder</bpmn:incoming>
      <bpmn:outgoing>Flow_Reminder_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_ReminderSent" name="Reminder cycle completed">
      <bpmn:incoming>Flow_Reminder_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_SendToPassportDirectorate" name="Send electronic information, print application, photograph and signature to Passport Directorate" messageRef="Message_PrintPackage">
      <bpmn:incoming>Flow_IssueLicense_SendPassport</bpmn:incoming>
      <bpmn:outgoing>Flow_SendPassport_HandOver</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Task_HandOverDrivingLicense" name="Hand over driving license in person at the submitting Service">
      <bpmn:incoming>Flow_SendPassport_HandOver</bpmn:incoming>
      <bpmn:outgoing>Flow_HandOver_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_LicenseDelivered" name="Driving license received by interested party">
      <bpmn:incoming>Flow_HandOver_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_ReminderTimer" name="Every 5 working days while not issued" cancelActivity="false" attachedToRef="Task_IssueDrivingLicense">
      <bpmn:outgoing>Flow_ReminderTimer_SendReminder</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_Reminder">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P5D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_Start_Check" sourceRef="StartEvent_ApplicationReceived" targetRef="Task_CheckDocuments" />
    <bpmn:sequenceFlow id="Flow_DocumentsReceived_Recheck" sourceRef="CatchEvent_DocumentsReceived" targetRef="Task_CheckDocuments" />
    <bpmn:sequenceFlow id="Flow_Check_Omissions" sourceRef="Task_CheckDocuments" targetRef="Gateway_OmissionsIdentified" />
    <bpmn:sequenceFlow id="Flow_Omissions_Inform" name="Yes" sourceRef="Gateway_OmissionsIdentified" targetRef="Task_InformInterestedParty">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${omissionsIdentified}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoOmissions_Register" name="No" sourceRef="Gateway_OmissionsIdentified" targetRef="Task_RegisterApplication">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!omissionsIdentified}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Inform_Wait" sourceRef="Task_InformInterestedParty" targetRef="Gateway_WaitForDocumentsOrDeadline" />
    <bpmn:sequenceFlow id="Flow_Wait_Documents" sourceRef="Gateway_WaitForDocumentsOrDeadline" targetRef="CatchEvent_DocumentsReceived" />
    <bpmn:sequenceFlow id="Flow_Wait_Timeout" sourceRef="Gateway_WaitForDocumentsOrDeadline" targetRef="CatchEvent_FifteenDaysElapsed" />
    <bpmn:sequenceFlow id="Flow_Timeout_End" sourceRef="CatchEvent_FifteenDaysElapsed" targetRef="EndEvent_NoDocuments" />
    <bpmn:sequenceFlow id="Flow_Register_Certificate" sourceRef="Task_RegisterApplication" targetRef="Task_ProvideCertificate" />
    <bpmn:sequenceFlow id="Flow_Certificate_ProvisionalDecision" sourceRef="Task_ProvideCertificate" targetRef="Gateway_ProvisionalRequired" />
    <bpmn:sequenceFlow id="Flow_Provisional_Issue" name="Yes" sourceRef="Gateway_ProvisionalRequired" targetRef="Task_IssueProvisionalLicense">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${provisionalLicenseRequired}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoProvisional_Merge" name="No" sourceRef="Gateway_ProvisionalRequired" targetRef="Gateway_ProvisionalMerge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!provisionalLicenseRequired}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Provisional_Merge" sourceRef="Task_IssueProvisionalLicense" targetRef="Gateway_ProvisionalMerge" />
    <bpmn:sequenceFlow id="Flow_Merge_IssueLicense" sourceRef="Gateway_ProvisionalMerge" targetRef="Task_IssueDrivingLicense" />
    <bpmn:sequenceFlow id="Flow_IssueLicense_SendPassport" sourceRef="Task_IssueDrivingLicense" targetRef="Task_SendToPassportDirectorate" />
    <bpmn:sequenceFlow id="Flow_ReminderTimer_SendReminder" sourceRef="BoundaryEvent_ReminderTimer" targetRef="Task_SendAutomatedReminder" />
    <bpmn:sequenceFlow id="Flow_Reminder_End" sourceRef="Task_SendAutomatedReminder" targetRef="EndEvent_ReminderSent" />
    <bpmn:sequenceFlow id="Flow_SendPassport_HandOver" sourceRef="Task_SendToPassportDirectorate" targetRef="Task_HandOverDrivingLicense" />
    <bpmn:sequenceFlow id="Flow_HandOver_End" sourceRef="Task_HandOverDrivingLicense" targetRef="EndEvent_LicenseDelivered" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_DrivingLicense">
    <bpmndi:BPMNPlane id="BPMNPlane_DrivingLicense" bpmnElement="Collaboration_DrivingLicense">
      <bpmndi:BPMNShape id="Shape_Participant_InterestedParty" bpmnElement="Participant_InterestedParty" isHorizontal="true">
        <dc:Bounds x="160" y="40" width="1960" height="90" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Participant_Service" bpmnElement="Participant_Service" isHorizontal="true">
        <dc:Bounds x="160" y="160" width="1960" height="500" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_AutomatedSystem" bpmnElement="Lane_AutomatedSystem" isHorizontal="true">
        <dc:Bounds x="190" y="530" width="1930" height="130" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Official" bpmnElement="Lane_Official" isHorizontal="true">
        <dc:Bounds x="190" y="160" width="1930" height="370" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_StartEvent" bpmnElement="StartEvent_ApplicationReceived">
        <dc:Bounds x="230" y="305" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="201" y="345" width="109" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_CheckDocuments" bpmnElement="Task_CheckDocuments">
        <dc:Bounds x="310" y="280" width="170" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_OmissionsGateway" bpmnElement="Gateway_OmissionsIdentified" isMarkerVisible="true">
        <dc:Bounds x="520" y="298" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="519" y="352" width="52" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_InformInterestedParty" bpmnElement="Task_InformInterestedParty">
        <dc:Bounds x="615" y="205" width="180" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_WaitGateway" bpmnElement="Gateway_WaitForDocumentsOrDeadline">
        <dc:Bounds x="835" y="223" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="815" y="180" width="101" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_DocumentsReceived" bpmnElement="CatchEvent_DocumentsReceived">
        <dc:Bounds x="935" y="200" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="908" y="165" width="99" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_FifteenDaysElapsed" bpmnElement="CatchEvent_FifteenDaysElapsed">
        <dc:Bounds x="935" y="300" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="896" y="340" width="119" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_NoDocumentsEnd" bpmnElement="EndEvent_NoDocuments">
        <dc:Bounds x="1045" y="300" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1020" y="340" width="95" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_RegisterApplication" bpmnElement="Task_RegisterApplication">
        <dc:Bounds x="615" y="405" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ProvideCertificate" bpmnElement="Task_ProvideCertificate">
        <dc:Bounds x="795" y="405" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ProvisionalDecision" bpmnElement="Gateway_ProvisionalRequired" isMarkerVisible="true">
        <dc:Bounds x="985" y="420" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="954" y="475" width="113" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_IssueProvisional" bpmnElement="Task_IssueProvisionalLicense">
        <dc:Bounds x="1075" y="350" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ProvisionalMerge" bpmnElement="Gateway_ProvisionalMerge" isMarkerVisible="true">
        <dc:Bounds x="1260" y="420" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1263" y="470" width="45" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_IssueDrivingLicense" bpmnElement="Task_IssueDrivingLicense">
        <dc:Bounds x="1350" y="390" width="180" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_SendAutomatedReminder" bpmnElement="Task_SendAutomatedReminder">
        <dc:Bounds x="1530" y="555" width="180" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ReminderEnd" bpmnElement="EndEvent_ReminderSent">
        <dc:Bounds x="1755" y="572" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1737" y="610" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_SendToPassport" bpmnElement="Task_SendToPassportDirectorate">
        <dc:Bounds x="1575" y="390" width="190" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_HandOverLicense" bpmnElement="Task_HandOverDrivingLicense">
        <dc:Bounds x="1810" y="400" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_LicenseDeliveredEnd" bpmnElement="EndEvent_LicenseDelivered">
        <dc:Bounds x="2030" y="422" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1994" y="460" width="108" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ReminderBoundary" bpmnElement="BoundaryEvent_ReminderTimer">
        <dc:Bounds x="1418" y="472" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1385" y="508" width="105" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_Check" bpmnElement="Flow_Start_Check">
        <di:waypoint x="266" y="323" />
        <di:waypoint x="310" y="323" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_DocumentsReceived_Recheck" bpmnElement="Flow_DocumentsReceived_Recheck">
        <di:waypoint x="953" y="200" />
        <di:waypoint x="953" y="175" />
        <di:waypoint x="395" y="175" />
        <di:waypoint x="395" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Check_Omissions" bpmnElement="Flow_Check_Omissions">
        <di:waypoint x="480" y="323" />
        <di:waypoint x="520" y="323" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Omissions_Inform" bpmnElement="Flow_Omissions_Inform">
        <di:waypoint x="545" y="298" />
        <di:waypoint x="545" y="248" />
        <di:waypoint x="615" y="248" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="558" y="252" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_NoOmissions_Register" bpmnElement="Flow_NoOmissions_Register">
        <di:waypoint x="545" y="348" />
        <di:waypoint x="545" y="445" />
        <di:waypoint x="615" y="445" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="559" y="425" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Inform_Wait" bpmnElement="Flow_Inform_Wait">
        <di:waypoint x="795" y="248" />
        <di:waypoint x="835" y="248" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Wait_Documents" bpmnElement="Flow_Wait_Documents">
        <di:waypoint x="885" y="248" />
        <di:waypoint x="910" y="248" />
        <di:waypoint x="910" y="218" />
        <di:waypoint x="935" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Wait_Timeout" bpmnElement="Flow_Wait_Timeout">
        <di:waypoint x="860" y="273" />
        <di:waypoint x="860" y="318" />
        <di:waypoint x="935" y="318" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Timeout_End" bpmnElement="Flow_Timeout_End">
        <di:waypoint x="971" y="318" />
