<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_OrderFulfillment" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:message id="Message_PurchaseOrder" name="Purchase order" />
  <bpmn:collaboration id="Collaboration_Seller">
    <bpmn:participant id="Participant_Seller" name="Seller" processRef="Process_OrderFulfillment" />
  </bpmn:collaboration>
  <bpmn:process id="Process_OrderFulfillment" name="Order Fulfillment" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Seller">
      <bpmn:lane id="Lane_Sales" name="Sales">
        <bpmn:flowNodeRef>Task_ConfirmOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceivePayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArchiveOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_OrderFulfilled</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_WarehouseDistribution" name="Warehouse &#38; Distribution">
        <bpmn:flowNodeRef>StartEvent_OrderReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_StockSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetrieveProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckRawMaterials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_InclSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_InclJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManufactureProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_StockJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipProduct</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_OrderReceived" name="Purchase order received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_PO" messageRef="Message_PurchaseOrder" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CheckStock" name="Check stock availability">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:property id="Property_CheckStock" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_Warehouse">
        <bpmn:sourceRef>DataStoreReference_WarehouseDB</bpmn:sourceRef>
        <bpmn:targetRef>Property_CheckStock</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_StockSplit" name="Product in stock?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_RetrieveProduct" name="Retrieve product from warehouse">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="Task_CheckRawMaterials" name="Check raw materials availability">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:property id="Property_CheckRawMaterials" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_Catalog">
        <bpmn:sourceRef>DataStoreReference_SuppliersCatalog</bpmn:sourceRef>
        <bpmn:targetRef>Property_CheckRawMaterials</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:serviceTask>
    <bpmn:inclusiveGateway id="Gateway_InclSplit" name="Raw materials needed from?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:task id="Task_OrderSupplier1" name="Order raw materials from Supplier 1">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_OrderSupplier2" name="Order raw materials from Supplier 2">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:inclusiveGateway id="Gateway_InclJoin">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:task id="Task_ManufactureProduct" name="Manufacture product">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_StockJoin">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ConfirmOrder" name="Confirm order">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_ParSplit">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_EmitInvoice" name="Emit invoice">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReceivePayment" name="Receive payment">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ShipProduct" name="Ship product">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_ParJoin">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_ArchiveOrder" name="Archive order">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_OrderFulfilled" name="Order fulfilled">
      <bpmn:incoming>Flow_21</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataStoreReference id="DataStoreReference_WarehouseDB" name="Warehouse database" />
    <bpmn:dataStoreReference id="DataStoreReference_SuppliersCatalog" name="Suppliers catalog" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_OrderReceived" targetRef="Task_CheckStock" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CheckStock" targetRef="Gateway_StockSplit" />
    <bpmn:sequenceFlow id="Flow_3" name="product in stock" sourceRef="Gateway_StockSplit" targetRef="Task_RetrieveProduct" />
    <bpmn:sequenceFlow id="Flow_4" name="product not in stock" sourceRef="Gateway_StockSplit" targetRef="Task_CheckRawMaterials" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_CheckRawMaterials" targetRef="Gateway_InclSplit" />
    <bpmn:sequenceFlow id="Flow_6" name="from Supplier 1" sourceRef="Gateway_InclSplit" targetRef="Task_OrderSupplier1" />
    <bpmn:sequenceFlow id="Flow_7" name="from Supplier 2" sourceRef="Gateway_InclSplit" targetRef="Task_OrderSupplier2" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_OrderSupplier1" targetRef="Gateway_InclJoin" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_OrderSupplier2" targetRef="Gateway_InclJoin" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Gateway_InclJoin" targetRef="Task_ManufactureProduct" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_ManufactureProduct" targetRef="Gateway_StockJoin" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_RetrieveProduct" targetRef="Gateway_StockJoin" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Gateway_StockJoin" targetRef="Task_ConfirmOrder" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_ConfirmOrder" targetRef="Gateway_ParSplit" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Gateway_ParSplit" targetRef="Task_EmitInvoice" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Gateway_ParSplit" targetRef="Task_ShipProduct" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_EmitInvoice" targetRef="Task_ReceivePayment" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_ReceivePayment" targetRef="Gateway_ParJoin" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="Task_ShipProduct" targetRef="Gateway_ParJoin" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="Gateway_ParJoin" targetRef="Task_ArchiveOrder" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="Task_ArchiveOrder" targetRef="EndEvent_OrderFulfilled" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_OrderFulfillment">
    <bpmndi:BPMNPlane id="BPMNPlane_OrderFulfillment" bpmnElement="Collaboration_Seller">
