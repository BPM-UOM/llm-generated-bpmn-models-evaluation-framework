<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_DrivingLicense" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Process_DrivingLicenseRenewal" name="Driving License Application and Renewal Process" isExecutable="true">
    <bpmn:startEvent id="Start_Event_Application_Received" name="Application and documents received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Check_Documents" name="Check completeness and correctness of documents">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_Docs_Resubmitted</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Omissions_Identified" name="Omissions identified?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Omissions_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Omissions_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Inform_Interested_Party" name="Inform interested party of omissions">
      <bpmn:incoming>Flow_Omissions_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:eventBasedGateway id="Gateway_Wait_For_Documents" name="Wait for documents or 15 days">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_To_Submit_Event</bpmn:outgoing>
      <bpmn:outgoing>Flow_To_Timer_Event</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_Documents_Submitted" name="Documents submitted within deadline">
      <bpmn:incoming>Flow_To_Submit_Event</bpmn:incoming>
      <bpmn:outgoing>Flow_Docs_Resubmitted</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_15_Days_Pass" name="15 days pass without submission">
      <bpmn:incoming>Flow_To_Timer_Event</bpmn:incoming>
      <bpmn:outgoing>Flow_Terminated</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1">
        <bpmn:timeDuration>P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="End_Event_Terminated" name="Process terminated">
      <bpmn:incoming>Flow_Terminated</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Register_Application" name="Register the application">
      <bpmn:incoming>Flow_Omissions_No</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Give_Certificate" name="Give Certificate of Submission of Request">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_License_Expired" name="Driving license expired or expires before printing?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Expired_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Expired_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Issue_Provisional_License" name="Issue provisional driving license">
      <bpmn:incoming>Flow_Expired_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Merge_Provisional</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Merge_Provisional_Flow">
      <bpmn:incoming>Flow_Expired_No</bpmn:incoming>
      <bpmn:incoming>Flow_Merge_Provisional</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Issue_Driving_License" name="Issue driving license via electronic entry in Register">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:boundaryEvent id="Boundary_Timer_5_Days" name="Every 5 working days" cancelActivity="false" attachedToRef="Task_Issue_Driving_License">
      <bpmn:outgoing>Flow_Reminder</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_2">
        <bpmn:timeCycle>R/P5D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:task id="Task_Send_Automated_Reminder" name="Send automated reminder to responsible official">
      <bpmn:incoming>Flow_Reminder</bpmn:incoming>
      <bpmn:outgoing>Flow_Reminder_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Event_Reminder" name="Reminder sent">
      <bpmn:incoming>Flow_Reminder_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Send_To_Passport_Directorate" name="Send info and print application to Passport Directorate of Hellenic Police">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Receive_License_In_Person" name="Receive driving license in person">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Event_Success" name="Process completed successfully">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_Event_Application_Received" targetRef="Task_Check_Documents" />
    <bpmn:sequenceFlow id="Flow_Docs_Resubmitted" sourceRef="Event_Documents_Submitted" targetRef="Task_Check_Documents" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Check_Documents" targetRef="Gateway_Omissions_Identified" />
    <bpmn:sequenceFlow id="Flow_Omissions_Yes" name="Yes" sourceRef="Gateway_Omissions_Identified" targetRef="Task_Inform_Interested_Party" />
    <bpmn:sequenceFlow id="Flow_Omissions_No" name="No" sourceRef="Gateway_Omissions_Identified" targetRef="Task_Register_Application" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Inform_Interested_Party" targetRef="Gateway_Wait_For_Documents" />
    <bpmn:sequenceFlow id="Flow_To_Submit_Event" sourceRef="Gateway_Wait_For_Documents" targetRef="Event_Documents_Submitted" />
    <bpmn:sequenceFlow id="Flow_To_Timer_Event" sourceRef="Gateway_Wait_For_Documents" targetRef="Event_15_Days_Pass" />
    <bpmn:sequenceFlow id="Flow_Terminated" sourceRef="Event_15_Days_Pass" targetRef="End_Event_Terminated" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Register_Application" targetRef="Task_Give_Certificate" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_Give_Certificate" targetRef="Gateway_License_Expired" />
    <bpmn:sequenceFlow id="Flow_Expired_Yes" name="Yes" sourceRef="Gateway_License_Expired" targetRef="Task_Issue_Provisional_License" />
    <bpmn:sequenceFlow id="Flow_Expired_No" name="No" sourceRef="Gateway_License_Expired" targetRef="Gateway_Merge_Provisional_Flow" />
    <bpmn:sequenceFlow id="Flow_Merge_Provisional" sourceRef="Task_Issue_Provisional_License" targetRef="Gateway_Merge_Provisional_Flow" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Gateway_Merge_Provisional_Flow" targetRef="Task_Issue_Driving_License" />
    <bpmn:sequenceFlow id="Flow_Reminder" sourceRef="Boundary_Timer_5_Days" targetRef="Task_Send_Automated_Reminder" />
    <bpmn:sequenceFlow id="Flow_Reminder_End" sourceRef="Task_Send_Automated_Reminder" targetRef="End_Event_Reminder" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_Issue_Driving_License" targetRef="Task_Send_To_Passport_Directorate" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_Send_To_Passport_Directorate" targetRef="Task_Receive_License_In_Person" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_Receive_License_In_Person" targetRef="End_Event_Success" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_DrivingLicenseRenewal">
