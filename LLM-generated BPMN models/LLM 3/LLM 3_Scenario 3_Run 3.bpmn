<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="DrivingLicenseRenewalProcess" name="Driving License Renewal Process" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Application Received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_CheckDocs" name="Check completeness and correctness of supporting documents">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_DocsSubmittedWithinDeadline</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Omissions" name="Omissions identified?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_OmissionsYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_OmissionsNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_InformParty" name="Inform interested party of omissions">
      <bpmn:incoming>Flow_OmissionsYes</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:eventBasedGateway id="Gateway_WaitEvent" name="Wait for submission or deadline">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_ToTimer</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToMessage</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_Timer15Days" name="15 days pass">
      <bpmn:incoming>Flow_ToTimer</bpmn:incoming>
      <bpmn:outgoing>Flow_TimerExpired</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_Terminated" name="Process Terminated">
      <bpmn:incoming>Flow_TimerExpired</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateCatchEvent id="Event_DocsSubmitted" name="Documents submitted">
      <bpmn:incoming>Flow_ToMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_DocsSubmittedWithinDeadline</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1" messageRef="Message_Docs" />
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="Task_RegisterApp" name="Register application">
      <bpmn:incoming>Flow_OmissionsNo</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_GiveCertificate" name="Give Certificate of Submission of Request">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ExpiryCheck" name="License expired or expires before printing?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_ExpiryYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_ExpiryNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_IssueProvisional" name="Issue provisional driving license">
      <bpmn:incoming>Flow_ExpiryYes</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_IssueLicense" name="Issue driving license via electronic entry in Register">
      <bpmn:incoming>Flow_ExpiryNo</bpmn:incoming>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Event_ReminderTimer" name="Every 5 working days" cancelActivity="false" attachedToRef="Task_IssueLicense">
      <bpmn:outgoing>Flow_ToReminder</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_2">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P5D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sendTask id="Task_SendReminder" name="Send automated reminder to responsible official">
      <bpmn:incoming>Flow_ToReminder</bpmn:incoming>
      <bpmn:outgoing>Flow_ReminderSent</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="EndEvent_Reminder" name="Reminder Sent">
      <bpmn:incoming>Flow_ReminderSent</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_SendToPolice" name="Send info and print application to Passport Directorate of Hellenic Police">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Task_ReceiveLicense" name="Person receives driving license in person">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Success" name="Driving License Issued and Received">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_CheckDocs" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CheckDocs" targetRef="Gateway_Omissions" />
    <bpmn:sequenceFlow id="Flow_OmissionsYes" name="Yes" sourceRef="Gateway_Omissions" targetRef="Task_InformParty" />
    <bpmn:sequenceFlow id="Flow_OmissionsNo" name="No" sourceRef="Gateway_Omissions" targetRef="Task_RegisterApp" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_InformParty" targetRef="Gateway_WaitEvent" />
    <bpmn:sequenceFlow id="Flow_ToTimer" sourceRef="Gateway_WaitEvent" targetRef="Event_Timer15Days" />
    <bpmn:sequenceFlow id="Flow_ToMessage" sourceRef="Gateway_WaitEvent" targetRef="Event_DocsSubmitted" />
    <bpmn:sequenceFlow id="Flow_TimerExpired" sourceRef="Event_Timer15Days" targetRef="EndEvent_Terminated" />
    <bpmn:sequenceFlow id="Flow_DocsSubmittedWithinDeadline" sourceRef="Event_DocsSubmitted" targetRef="Task_CheckDocs" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_RegisterApp" targetRef="Task_GiveCertificate" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_GiveCertificate" targetRef="Gateway_ExpiryCheck" />
    <bpmn:sequenceFlow id="Flow_ExpiryYes" name="Yes" sourceRef="Gateway_ExpiryCheck" targetRef="Task_IssueProvisional" />
    <bpmn:sequenceFlow id="Flow_ExpiryNo" name="No" sourceRef="Gateway_ExpiryCheck" targetRef="Task_IssueLicense" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_IssueProvisional" targetRef="Task_IssueLicense" />
    <bpmn:sequenceFlow id="Flow_ToReminder" sourceRef="Event_ReminderTimer" targetRef="Task_SendReminder" />
    <bpmn:sequenceFlow id="Flow_ReminderSent" sourceRef="Task_SendReminder" targetRef="EndEvent_Reminder" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_IssueLicense" targetRef="Task_SendToPolice" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_SendToPolice" targetRef="Task_ReceiveLicense" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_ReceiveLicense" targetRef="EndEvent_Success" />
  </bpmn:process>
  <bpmn:message id="Message_Docs" name="Documents Submitted Message" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="DrivingLicenseRenewalProcess">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
