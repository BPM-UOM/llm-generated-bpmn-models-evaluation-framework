<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_DrivingLicenseProcess" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Process_DrivingLicenseRenewal" name="Driving License Renewal Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Application and supporting documents received">
      <bpmn:outgoing>SequenceFlow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Activity_CheckDocs" name="Check completeness and correctness of supporting documents">
      <bpmn:incoming>SequenceFlow_1</bpmn:incoming>
      <bpmn:incoming>SequenceFlow_LoopDocs</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_CheckOmissions" name="Omissions identified?">
      <bpmn:incoming>SequenceFlow_2</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_OmissionsYes</bpmn:outgoing>
      <bpmn:outgoing>SequenceFlow_OmissionsNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_InformParty" name="Inform interested party of omissions">
      <bpmn:incoming>SequenceFlow_OmissionsYes</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:eventBasedGateway id="Gateway_WaitEvents" name="Wait for submission or deadline">
      <bpmn:incoming>SequenceFlow_3</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_WaitDocs</bpmn:outgoing>
      <bpmn:outgoing>SequenceFlow_WaitTimer</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_DocsSubmitted" name="Interested party submits requested documents">
      <bpmn:incoming>SequenceFlow_WaitDocs</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_LoopDocs</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_Timer15Days" name="15 days pass">
      <bpmn:incoming>SequenceFlow_WaitTimer</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_Terminated</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="Event_ProcessTerminated" name="Process terminated">
      <bpmn:incoming>SequenceFlow_Terminated</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Activity_RegisterApp" name="Register the application">
      <bpmn:incoming>SequenceFlow_OmissionsNo</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_GiveCert" name="Give Certificate of Submission of Request">
      <bpmn:incoming>SequenceFlow_4</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_CheckExpiry" name="Driving license expired or expires before printing?">
      <bpmn:incoming>SequenceFlow_5</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_ExpiryYes</bpmn:outgoing>
      <bpmn:outgoing>SequenceFlow_ExpiryNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_IssueProvisional" name="Issue provisional driving license">
      <bpmn:incoming>SequenceFlow_ExpiryYes</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_MergeProvisional">
      <bpmn:incoming>SequenceFlow_ExpiryNo</bpmn:incoming>
      <bpmn:incoming>SequenceFlow_6</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_IssueLicense" name="Issue driving license via electronic entry in Register">
      <bpmn:incoming>SequenceFlow_7</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Event_TimerReminder" name="Every 5 working days" cancelActivity="false" attachedToRef="Activity_IssueLicense">
      <bpmn:outgoing>SequenceFlow_Reminder</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_2">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P5D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sendTask id="Activity_SendReminder" name="Send automated reminder to responsible official">
      <bpmn:incoming>SequenceFlow_Reminder</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_ReminderEnd</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_ReminderSent" name="Reminder sent">
      <bpmn:incoming>SequenceFlow_ReminderEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Activity_SendToPassport" name="Send info and print application to Passport Directorate of Hellenic Police">
      <bpmn:incoming>SequenceFlow_8</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_9</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Activity_ReceiveLicense" name="Person receives driving license in person">
      <bpmn:incoming>SequenceFlow_9</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_ProcessCompleted" name="Process completed successfully">
      <bpmn:incoming>SequenceFlow_10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SequenceFlow_1" sourceRef="StartEvent_1" targetRef="Activity_CheckDocs" />
    <bpmn:sequenceFlow id="SequenceFlow_2" sourceRef="Activity_CheckDocs" targetRef="Gateway_CheckOmissions" />
    <bpmn:sequenceFlow id="SequenceFlow_OmissionsYes" name="Yes" sourceRef="Gateway_CheckOmissions" targetRef="Activity_InformParty" />
    <bpmn:sequenceFlow id="SequenceFlow_OmissionsNo" name="No" sourceRef="Gateway_CheckOmissions" targetRef="Activity_RegisterApp" />
    <bpmn:sequenceFlow id="SequenceFlow_3" sourceRef="Activity_InformParty" targetRef="Gateway_WaitEvents" />
    <bpmn:sequenceFlow id="SequenceFlow_WaitDocs" sourceRef="Gateway_WaitEvents" targetRef="Event_DocsSubmitted" />
    <bpmn:sequenceFlow id="SequenceFlow_WaitTimer" sourceRef="Gateway_WaitEvents" targetRef="Event_Timer15Days" />
    <bpmn:sequenceFlow id="SequenceFlow_LoopDocs" sourceRef="Event_DocsSubmitted" targetRef="Activity_CheckDocs" />
    <bpmn:sequenceFlow id="SequenceFlow_Terminated" sourceRef="Event_Timer15Days" targetRef="Event_ProcessTerminated" />
    <bpmn:sequenceFlow id="SequenceFlow_4" sourceRef="Activity_RegisterApp" targetRef="Activity_GiveCert" />
    <bpmn:sequenceFlow id="SequenceFlow_5" sourceRef="Activity_GiveCert" targetRef="Gateway_CheckExpiry" />
    <bpmn:sequenceFlow id="SequenceFlow_ExpiryYes" name="Yes" sourceRef="Gateway_CheckExpiry" targetRef="Activity_IssueProvisional" />
    <bpmn:sequenceFlow id="SequenceFlow_ExpiryNo" name="No" sourceRef="Gateway_CheckExpiry" targetRef="Gateway_MergeProvisional" />
    <bpmn:sequenceFlow id="SequenceFlow_6" sourceRef="Activity_IssueProvisional" targetRef="Gateway_MergeProvisional" />
    <bpmn:sequenceFlow id="SequenceFlow_7" sourceRef="Gateway_MergeProvisional" targetRef="Activity_IssueLicense" />
    <bpmn:sequenceFlow id="SequenceFlow_Reminder" sourceRef="Event_TimerReminder" targetRef="Activity_SendReminder" />
    <bpmn:sequenceFlow id="SequenceFlow_ReminderEnd" sourceRef="Activity_SendReminder" targetRef="Event_ReminderSent" />
    <bpmn:sequenceFlow id="SequenceFlow_8" sourceRef="Activity_IssueLicense" targetRef="Activity_SendToPassport" />
    <bpmn:sequenceFlow id="SequenceFlow_9" sourceRef="Activity_SendToPassport" targetRef="Activity_ReceiveLicense" />
    <bpmn:sequenceFlow id="SequenceFlow_10" sourceRef="Activity_ReceiveLicense" targetRef="Event_ProcessCompleted" />
  </bpmn:process>
