<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_SellerOrg" name="Seller&#39;s Organization" processRef="Process_OrderFulfillment" />
  </bpmn:collaboration>
  <bpmn:process id="Process_OrderFulfillment" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Sales" name="Sales Department">
        <bpmn:flowNodeRef>Task_ConfirmOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_WaitPayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArchiveOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_OrderCompleted</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Warehouse" name="Warehouse &#38; Distribution Department">
        <bpmn:flowNodeRef>StartEvent_OrderReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_InStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckRawMaterials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SupplierSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SupplierJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManufactureProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetrieveProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_StockJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipProduct</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_OrderReceived" name="Purchase order received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CheckStock" name="Check stock via ERP">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_InStock" name="Product in stock?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_InStock_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_InStock_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_CheckRawMaterials" name="Check raw materials availability">
      <bpmn:incoming>Flow_InStock_No</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:inclusiveGateway id="Gateway_SupplierSplit" name="Select Supplier(s)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSupplier1</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToSupplier2</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:sendTask id="Task_OrderSupplier1" name="Order raw materials from Supplier 1">
      <bpmn:incoming>Flow_ToSupplier1</bpmn:incoming>
      <bpmn:outgoing>Flow_FromSupplier1</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Task_OrderSupplier2" name="Order raw materials from Supplier 2">
      <bpmn:incoming>Flow_ToSupplier2</bpmn:incoming>
      <bpmn:outgoing>Flow_FromSupplier2</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:inclusiveGateway id="Gateway_SupplierJoin">
      <bpmn:incoming>Flow_FromSupplier1</bpmn:incoming>
      <bpmn:incoming>Flow_FromSupplier2</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:userTask id="Task_ManufactureProduct" name="Manufacture product">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_RetrieveProduct" name="Retrieve product from warehouse">
      <bpmn:incoming>Flow_InStock_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_StockJoin">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ConfirmOrder" name="Confirm order">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_ParallelSplit">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_ToInvoice</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToShip</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_EmitInvoice" name="Emit invoice">
      <bpmn:incoming>Flow_ToInvoice</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="Event_WaitPayment" name="Wait for payment">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Payment" />
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="Task_ShipProduct" name="Ship product">
      <bpmn:incoming>Flow_ToShip</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_ParallelJoin">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_ArchiveOrder" name="Archive order">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_OrderCompleted" name="Order completed">
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_OrderReceived" targetRef="Task_CheckStock" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CheckStock" targetRef="Gateway_InStock" />
    <bpmn:sequenceFlow id="Flow_InStock_No" name="No" sourceRef="Gateway_InStock" targetRef="Task_CheckRawMaterials" />
    <bpmn:sequenceFlow id="Flow_InStock_Yes" name="Yes" sourceRef="Gateway_InStock" targetRef="Task_RetrieveProduct" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_CheckRawMaterials" targetRef="Gateway_SupplierSplit" />
    <bpmn:sequenceFlow id="Flow_ToSupplier1" name="Supplier 1" sourceRef="Gateway_SupplierSplit" targetRef="Task_OrderSupplier1" />
    <bpmn:sequenceFlow id="Flow_ToSupplier2" name="Supplier 2" sourceRef="Gateway_SupplierSplit" targetRef="Task_OrderSupplier2" />
    <bpmn:sequenceFlow id="Flow_FromSupplier1" sourceRef="Task_OrderSupplier1" targetRef="Gateway_SupplierJoin" />
    <bpmn:sequenceFlow id="Flow_FromSupplier2" sourceRef="Task_OrderSupplier2" targetRef="Gateway_SupplierJoin" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Gateway_SupplierJoin" targetRef="Task_ManufactureProduct" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_ManufactureProduct" targetRef="Gateway_StockJoin" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_RetrieveProduct" targetRef="Gateway_StockJoin" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Gateway_StockJoin" targetRef="Task_ConfirmOrder" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_ConfirmOrder" targetRef="Gateway_ParallelSplit" />
    <bpmn:sequenceFlow id="Flow_ToInvoice" sourceRef="Gateway_ParallelSplit" targetRef="Task_EmitInvoice" />
    <bpmn:sequenceFlow id="Flow_ToShip" sourceRef="Gateway_ParallelSplit" targetRef="Task_ShipProduct" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_EmitInvoice" targetRef="Event_WaitPayment" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Event_WaitPayment" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_ShipProduct" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Gateway_ParallelJoin" targetRef="Task_ArchiveOrder" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_ArchiveOrder" targetRef="EndEvent_OrderCompleted" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_SellerOrg_di" bpmnElement="Participant_SellerOrg" isHorizontal="true">
        <dc:Bounds x="160" y="100" width="1980" height="500" />
