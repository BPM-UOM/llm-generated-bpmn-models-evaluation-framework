<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Seller Organization" processRef="Process_OrderFulfillment" />
  </bpmn:collaboration>
  <bpmn:process id="Process_OrderFulfillment" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Warehouse" name="Warehouse &#38; Distribution Department">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_InStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetrieveProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckRawMaterials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_OrderSupplier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MergeSupplier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manufacture</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipProduct</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Sales" name="Sales Department">
        <bpmn:flowNodeRef>Gateway_MergeConfirm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConfirmOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_WaitPayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArchiveOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Purchase Order Received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CheckStock" name="Check Stock against Database">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_InStock" name="Product in stock?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_InStock_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_InStock_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="Task_RetrieveProduct" name="Retrieve Product from Warehouse">
      <bpmn:incoming>Flow_InStock_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_R_Confirm</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:serviceTask id="Task_CheckRawMaterials" name="Check Raw Materials Availability">
      <bpmn:incoming>Flow_InStock_No</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:inclusiveGateway id="Gateway_OrderSupplier" name="Supplier Selection">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Sup1</bpmn:outgoing>
      <bpmn:outgoing>Flow_Sup2</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:task id="Task_OrderSupplier1" name="Order from Supplier 1">
      <bpmn:incoming>Flow_Sup1</bpmn:incoming>
      <bpmn:outgoing>Flow_Sup1_M</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_OrderSupplier2" name="Order from Supplier 2">
      <bpmn:incoming>Flow_Sup2</bpmn:incoming>
      <bpmn:outgoing>Flow_Sup2_M</bpmn:outgoing>
    </bpmn:task>
    <bpmn:inclusiveGateway id="Gateway_MergeSupplier" name="Merge Supplier Orders">
      <bpmn:incoming>Flow_Sup1_M</bpmn:incoming>
      <bpmn:incoming>Flow_Sup2_M</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:manualTask id="Task_Manufacture" name="Manufacture Product">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_M_Confirm</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:exclusiveGateway id="Gateway_MergeConfirm" name="Merge Confirmation Paths">
      <bpmn:incoming>Flow_M_Confirm</bpmn:incoming>
      <bpmn:incoming>Flow_R_Confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ConfirmOrder" name="Confirm Order">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_ParallelSplit" name="Split Invoice and Shipping">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_Invoice</bpmn:outgoing>
      <bpmn:outgoing>Flow_Ship</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_EmitInvoice" name="Emit Invoice">
      <bpmn:incoming>Flow_Invoice</bpmn:incoming>
      <bpmn:outgoing>Flow_Payment</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:receiveTask id="Task_WaitPayment" name="Wait for Payment">
      <bpmn:incoming>Flow_Payment</bpmn:incoming>
      <bpmn:outgoing>Flow_Pay_M</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:task id="Task_ShipProduct" name="Ship Product">
      <bpmn:incoming>Flow_Ship</bpmn:incoming>
      <bpmn:outgoing>Flow_Ship_M</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_ParallelMerge" name="Merge Invoice and Shipping">
      <bpmn:incoming>Flow_Pay_M</bpmn:incoming>
      <bpmn:incoming>Flow_Ship_M</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_ArchiveOrder" name="Archive Order">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_1" name="Process Completed">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_CheckStock" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CheckStock" targetRef="Gateway_InStock" />
    <bpmn:sequenceFlow id="Flow_InStock_Yes" name="Yes" sourceRef="Gateway_InStock" targetRef="Task_RetrieveProduct" />
    <bpmn:sequenceFlow id="Flow_InStock_No" name="No" sourceRef="Gateway_InStock" targetRef="Task_CheckRawMaterials" />
    <bpmn:sequenceFlow id="Flow_R_Confirm" sourceRef="Task_RetrieveProduct" targetRef="Gateway_MergeConfirm" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_CheckRawMaterials" targetRef="Gateway_OrderSupplier" />
    <bpmn:sequenceFlow id="Flow_Sup1" sourceRef="Gateway_OrderSupplier" targetRef="Task_OrderSupplier1" />
    <bpmn:sequenceFlow id="Flow_Sup2" sourceRef="Gateway_OrderSupplier" targetRef="Task_OrderSupplier2" />
    <bpmn:sequenceFlow id="Flow_Sup1_M" sourceRef="Task_OrderSupplier1" targetRef="Gateway_MergeSupplier" />
    <bpmn:sequenceFlow id="Flow_Sup2_M" sourceRef="Task_OrderSupplier2" targetRef="Gateway_MergeSupplier" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Gateway_MergeSupplier" targetRef="Task_Manufacture" />
    <bpmn:sequenceFlow id="Flow_M_Confirm" sourceRef="Task_Manufacture" targetRef="Gateway_MergeConfirm" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_MergeConfirm" targetRef="Task_ConfirmOrder" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_ConfirmOrder" targetRef="Gateway_ParallelSplit" />
    <bpmn:sequenceFlow id="Flow_Invoice" sourceRef="Gateway_ParallelSplit" targetRef="Task_EmitInvoice" />
    <bpmn:sequenceFlow id="Flow_Ship" sourceRef="Gateway_ParallelSplit" targetRef="Task_ShipProduct" />
    <bpmn:sequenceFlow id="Flow_Payment" sourceRef="Task_EmitInvoice" targetRef="Task_WaitPayment" />
    <bpmn:sequenceFlow id="Flow_Pay_M" sourceRef="Task_WaitPayment" targetRef="Gateway_ParallelMerge" />
    <bpmn:sequenceFlow id="Flow_Ship_M" sourceRef="Task_ShipProduct" targetRef="Gateway_ParallelMerge" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Gateway_ParallelMerge" targetRef="Task_ArchiveOrder" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_ArchiveOrder" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
