<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Process_ClaimHandling" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Claim registered">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_Examine" name="Examine claim">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Recommend" name="Write settlement recommendation">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:incoming>Flow_NotOK</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Check" name="Check settlement recommendation">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Check" name="Marked as OK?">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_OK</bpmn:outgoing>
      <bpmn:outgoing>Flow_NotOK</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_Proceed" name="Process proceeds">
      <bpmn:incoming>Flow_OK</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Activity_Examine" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Activity_Examine" targetRef="Activity_Recommend" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Activity_Recommend" targetRef="Activity_Check" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Activity_Check" targetRef="Gateway_Check" />
    <bpmn:sequenceFlow id="Flow_OK" name="OK" sourceRef="Gateway_Check" targetRef="EndEvent_Proceed" />
    <bpmn:sequenceFlow id="Flow_NotOK" name="Not OK" sourceRef="Gateway_Check" targetRef="Activity_Recommend" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_ClaimHandling">
      <bpmndi:BPMNShape id="_BPMNShape_StartEvent_2" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="130" y="205" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Examine_di" bpmnElement="Activity_Examine">
        <dc:Bounds x="240" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Recommend_di" bpmnElement="Activity_Recommend">
        <dc:Bounds x="400" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Check_di" bpmnElement="Activity_Check">
        <dc:Bounds x="560" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Check_di" bpmnElement="Gateway_Check" isMarkerVisible="true">
        <dc:Bounds x="725" y="155" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="712" y="212" width="77" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Proceed_di" bpmnElement="EndEvent_Proceed">
        <dc:Bounds x="842" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="816" y="205" width="89" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="188" y="180" />
        <di:waypoint x="240" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="340" y="180" />
        <di:waypoint x="400" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotOK_di" bpmnElement="Flow_NotOK">
        <di:waypoint x="750" y="155" />
        <di:waypoint x="750" y="100" />
        <di:waypoint x="450" y="100" />
        <di:waypoint x="450" y="140" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="582" y="82" width="37" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="500" y="180" />
        <di:waypoint x="560" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="660" y="180" />
        <di:waypoint x="725" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_OK_di" bpmnElement="Flow_OK">
        <di:waypoint x="775" y="180" />
        <di:waypoint x="842" y="180" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="797" y="162" width="16" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
