<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_DrivingLicense" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:message id="Message_Application" name="Application - solemn declaration and supporting documents" />
  <bpmn:message id="Message_AdditionalDocs" name="Requested additional documents" />
  <bpmn:process id="Process_DrivingLicenseIssuance" name="Issuance of Driving License - Transport and Communications Service of the Regional Unit" isExecutable="false">
    <bpmn:startEvent id="StartEvent_ApplicationReceived" name="Application and supporting documents received (in person or digitally)">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Start" messageRef="Message_Application" />
    </bpmn:startEvent>
    <bpmn:userTask id="Task_CheckDocuments" name="Check completeness and correctness of supporting documents">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Omissions" name="Omissions identified?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_InformInterestedParty" name="Inform interested party of the need to provide additional information">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:eventBasedGateway id="Gateway_WaitForDocsOrDeadline" name="Wait for documents or deadline">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_DocumentsSubmitted" name="Requested documents submitted">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_DocsSubmitted" messageRef="Message_AdditionalDocs" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_Deadline15Days" name="15 days pass without submission">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_15Days">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_Terminated" name="Process terminated">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_RegisterApplication" name="Register the application">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_GiveCertificate" name="Give Certificate of Submission of Request to the person concerned">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_LicenseExpired" name="License expired or expires before printing of new form?">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_IssueProvisionalLicense" name="Issue provisional driving license to the person concerned">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Merge">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_IssueLicense" name="Issue driving license by electronic entry in the Driving License Register">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="BoundaryEvent_Reminder" name="Every 5 working days (while license not issued)" cancelActivity="false" attachedToRef="Task_IssueLicense">
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_5DayCycle">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P5D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="Task_SendReminder" name="Send automated reminder to the responsible official">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_ReminderSent" name="Reminder sent">
      <bpmn:incoming>Flow_20</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_SendToPassportDirectorate" name="Send electronic information and print application (with photograph and signature) to the Passport Directorate of the Hellenic Police">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Task_DeliverLicense" name="Deliver driving license in person to the person concerned at the Transport and Communications Service">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_LicenseReceived" name="Driving license received">
      <bpmn:incoming>Flow_18</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_ApplicationReceived" targetRef="Task_CheckDocuments" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CheckDocuments" targetRef="Gateway_Omissions" />
    <bpmn:sequenceFlow id="Flow_3" name="Yes" sourceRef="Gateway_Omissions" targetRef="Task_InformInterestedParty" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_InformInterestedParty" targetRef="Gateway_WaitForDocsOrDeadline" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_WaitForDocsOrDeadline" targetRef="Event_DocumentsSubmitted" />
    <bpmn:sequenceFlow id="Flow_6" name="Re-check documents" sourceRef="Event_DocumentsSubmitted" targetRef="Task_CheckDocuments" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Gateway_WaitForDocsOrDeadline" targetRef="Event_Deadline15Days" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Event_Deadline15Days" targetRef="EndEvent_Terminated" />
    <bpmn:sequenceFlow id="Flow_9" name="No" sourceRef="Gateway_Omissions" targetRef="Task_RegisterApplication" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_RegisterApplication" targetRef="Task_GiveCertificate" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_GiveCertificate" targetRef="Gateway_LicenseExpired" />
    <bpmn:sequenceFlow id="Flow_12" name="Yes" sourceRef="Gateway_LicenseExpired" targetRef="Task_IssueProvisionalLicense" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_IssueProvisionalLicense" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_14" name="No" sourceRef="Gateway_LicenseExpired" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Gateway_Merge" targetRef="Task_IssueLicense" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_IssueLicense" targetRef="Task_SendToPassportDirectorate" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_SendToPassportDirectorate" targetRef="Task_DeliverLicense" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_DeliverLicense" targetRef="EndEvent_LicenseReceived" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="BoundaryEvent_Reminder" targetRef="Task_SendReminder" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="Task_SendReminder" targetRef="EndEvent_ReminderSent" />
  </bpmn:process>
