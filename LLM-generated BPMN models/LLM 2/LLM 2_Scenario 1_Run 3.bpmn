<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_ClaimHandling" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Insurer" name="Insurance Company" processRef="Process_ClaimHandling" />
  </bpmn:collaboration>
  <bpmn:process id="Process_ClaimHandling" name="Claim Handling" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_ClaimsOfficer" name="Claims Officer">
        <bpmn:flowNodeRef>StartEvent_ClaimRegistered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ExamineClaim</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_WriteRecommendation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_SeniorClaimsOfficer" name="Senior Claims Officer">
        <bpmn:flowNodeRef>Task_CheckRecommendation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RecommendationOK</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ClaimHandlingProceeds</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_ClaimRegistered" name="Claim registered">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_ExamineClaim" name="Examine claim">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_WriteRecommendation" name="Write settlement recommendation">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:incoming>Flow_NotOK</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CheckRecommendation" name="Check recommendation">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_RecommendationOK" name="Recommendation OK?">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_OK</bpmn:outgoing>
      <bpmn:outgoing>Flow_NotOK</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_ClaimHandlingProceeds" name="Claim handling proceeds">
      <bpmn:incoming>Flow_OK</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_ClaimRegistered" targetRef="Task_ExamineClaim" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ExamineClaim" targetRef="Task_WriteRecommendation" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_WriteRecommendation" targetRef="Task_CheckRecommendation" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_CheckRecommendation" targetRef="Gateway_RecommendationOK" />
    <bpmn:sequenceFlow id="Flow_OK" name="OK" sourceRef="Gateway_RecommendationOK" targetRef="EndEvent_ClaimHandlingProceeds">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${recommendationOK == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NotOK" name="Not OK" sourceRef="Gateway_RecommendationOK" targetRef="Task_WriteRecommendation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${recommendationOK == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_Insurer_di" bpmnElement="Participant_Insurer" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="790" height="340" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_SeniorClaimsOfficer_di" bpmnElement="Lane_SeniorClaimsOfficer" isHorizontal="true">
        <dc:Bounds x="190" y="250" width="760" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_ClaimsOfficer_di" bpmnElement="Lane_ClaimsOfficer" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="760" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_ClaimRegistered_di" bpmnElement="StartEvent_ClaimRegistered">
        <dc:Bounds x="230" y="147" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="208" y="190" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ExamineClaim_di" bpmnElement="Task_ExamineClaim">
        <dc:Bounds x="320" y="125" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_WriteRecommendation_di" bpmnElement="Task_WriteRecommendation">
        <dc:Bounds x="470" y="125" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckRecommendation_di" bpmnElement="Task_CheckRecommendation">
        <dc:Bounds x="620" y="295" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RecommendationOK_di" bpmnElement="Gateway_RecommendationOK" isMarkerVisible="true">
        <dc:Bounds x="770" y="310" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="750" y="367" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ClaimHandlingProceeds_di" bpmnElement="EndEvent_ClaimHandlingProceeds">
        <dc:Bounds x="870" y="317" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="848" y="360" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="266" y="165" />
        <di:waypoint x="320" y="165" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="420" y="165" />
        <di:waypoint x="470" y="165" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="570" y="165" />
        <di:waypoint x="595" y="165" />
        <di:waypoint x="595" y="335" />
        <di:waypoint x="620" y="335" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="720" y="335" />
        <di:waypoint x="770" y="335" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_OK_di" bpmnElement="Flow_OK">
        <di:waypoint x="820" y="335" />
        <di:waypoint x="870" y="335" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="832" y="317" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotOK_di" bpmnElement="Flow_NotOK">
        <di:waypoint x="795" y="310" />
        <di:waypoint x="795" y="105" />
        <di:waypoint x="520" y="105" />
        <di:waypoint x="520" y="125" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="800" y="230" width="40" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
