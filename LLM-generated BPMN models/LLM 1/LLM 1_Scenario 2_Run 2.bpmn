<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:xsd="http://www.w3.org/2001/XMLSchema" id="Definitions_OrderFulfillment" targetNamespace="http://example.com/bpmn/order-fulfillment" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:message id="Message_PurchaseOrder" name="Purchase Order" />
  <bpmn:message id="Message_Invoice" name="Invoice" />
  <bpmn:message id="Message_Payment" name="Payment" />
  <bpmn:message id="Message_OrderSupplier1" name="Raw Material Order for Supplier 1" />
  <bpmn:message id="Message_MaterialsSupplier1" name="Raw Materials from Supplier 1" />
  <bpmn:message id="Message_OrderSupplier2" name="Raw Material Order for Supplier 2" />
  <bpmn:message id="Message_MaterialsSupplier2" name="Raw Materials from Supplier 2" />
  <bpmn:dataStore id="DataStore_WarehouseDB" name="Warehouse Database" />
  <bpmn:dataStore id="DataStore_SuppliersCatalog" name="Suppliers Catalog" />
  <bpmn:collaboration id="Collaboration_OrderFulfillment">
    <bpmn:participant id="Participant_Customer" name="Customer" />
    <bpmn:participant id="Participant_Seller" name="Seller Organization" processRef="Process_OrderFulfillment" />
    <bpmn:participant id="Participant_Supplier1" name="Supplier 1" />
    <bpmn:participant id="Participant_Supplier2" name="Supplier 2" />
    <bpmn:messageFlow id="MessageFlow_PurchaseOrder" name="Purchase order" sourceRef="Participant_Customer" targetRef="StartEvent_PurchaseOrder" />
    <bpmn:messageFlow id="MessageFlow_Invoice" name="Invoice" sourceRef="SendTask_IssueInvoice" targetRef="Participant_Customer" />
    <bpmn:messageFlow id="MessageFlow_Payment" name="Payment" sourceRef="Participant_Customer" targetRef="CatchEvent_Payment" />
    <bpmn:messageFlow id="MessageFlow_Shipment" name="Product shipment" sourceRef="Task_ShipProduct" targetRef="Participant_Customer" />
    <bpmn:messageFlow id="MessageFlow_OrderSupplier1" name="Raw material order" sourceRef="SendTask_OrderSupplier1" targetRef="Participant_Supplier1" />
    <bpmn:messageFlow id="MessageFlow_MaterialsSupplier1" name="Raw materials" sourceRef="Participant_Supplier1" targetRef="CatchEvent_MaterialsSupplier1" />
    <bpmn:messageFlow id="MessageFlow_OrderSupplier2" name="Raw material order" sourceRef="SendTask_OrderSupplier2" targetRef="Participant_Supplier2" />
    <bpmn:messageFlow id="MessageFlow_MaterialsSupplier2" name="Raw materials" sourceRef="Participant_Supplier2" targetRef="CatchEvent_MaterialsSupplier2" />
  </bpmn:collaboration>
  <bpmn:process id="Process_OrderFulfillment" name="Order Fulfillment" isExecutable="false">
    <bpmn:laneSet id="LaneSet_SellerDepartments">
      <bpmn:lane id="Lane_WarehouseDistribution" name="Warehouse &#38; Distribution Department">
        <bpmn:flowNodeRef>StartEvent_PurchaseOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_CheckStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ProductInStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_CheckRawMaterials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SelectSuppliers</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_OrderSupplier1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEvent_MaterialsSupplier1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_OrderSupplier2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEvent_MaterialsSupplier2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MaterialsReady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManufactureProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetrieveProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipProduct</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Sales" name="Sales Department">
        <bpmn:flowNodeRef>Gateway_ProductReady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConfirmOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_IssueInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEvent_Payment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArchiveOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_OrderArchived</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_PurchaseOrder" name="Purchase Order Received">
      <bpmn:outgoing>Flow_Start_CheckStock</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_PurchaseOrder" messageRef="Message_PurchaseOrder" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="ServiceTask_CheckStock" name="ERP: Check Product Stock">
      <bpmn:incoming>Flow_Start_CheckStock</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckStock_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_ProductInStock" name="Product in stock?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_CheckStock_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_StockYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_StockNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ServiceTask_CheckRawMaterials" name="ERP: Check Raw Material Availability">
      <bpmn:incoming>Flow_StockNo</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckMaterials_SelectSuppliers</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:inclusiveGateway id="Gateway_SelectSuppliers" name="Required supplier(s)" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_CheckMaterials_SelectSuppliers</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSupplier1</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToSupplier2</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:sendTask id="SendTask_OrderSupplier1" name="Order Raw Materials from Supplier 1" messageRef="Message_OrderSupplier1">
      <bpmn:incoming>Flow_ToSupplier1</bpmn:incoming>
      <bpmn:outgoing>Flow_OrderSupplier1_Wait</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="CatchEvent_MaterialsSupplier1" name="Materials from Supplier 1 Received">
      <bpmn:incoming>Flow_OrderSupplier1_Wait</bpmn:incoming>
      <bpmn:outgoing>Flow_Supplier1_Join</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_MaterialsSupplier1" messageRef="Message_MaterialsSupplier1" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sendTask id="SendTask_OrderSupplier2" name="Order Raw Materials from Supplier 2" messageRef="Message_OrderSupplier2">
      <bpmn:incoming>Flow_ToSupplier2</bpmn:incoming>
      <bpmn:outgoing>Flow_OrderSupplier2_Wait</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="CatchEvent_MaterialsSupplier2" name="Materials from Supplier 2 Received">
      <bpmn:incoming>Flow_OrderSupplier2_Wait</bpmn:incoming>
      <bpmn:outgoing>Flow_Supplier2_Join</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_MaterialsSupplier2" messageRef="Message_MaterialsSupplier2" />
    </bpmn:intermediateCatchEvent>
    <bpmn:inclusiveGateway id="Gateway_MaterialsReady" name="All Required Materials Obtained" gatewayDirection="Converging">
      <bpmn:incoming>Flow_Supplier1_Join</bpmn:incoming>
      <bpmn:incoming>Flow_Supplier2_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_MaterialsReady_Manufacture</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:task id="Task_ManufactureProduct" name="Manufacture Product">
      <bpmn:incoming>Flow_MaterialsReady_Manufacture</bpmn:incoming>
      <bpmn:outgoing>Flow_Manufacture_ProductReady</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RetrieveProduct" name="Retrieve Product from Warehouse">
      <bpmn:incoming>Flow_StockYes</bpmn:incoming>
      <bpmn:outgoing>Flow_Retrieve_ProductReady</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ProductReady" name="Product Ready" gatewayDirection="Converging">
      <bpmn:incoming>Flow_Manufacture_ProductReady</bpmn:incoming>
      <bpmn:incoming>Flow_Retrieve_ProductReady</bpmn:incoming>
      <bpmn:outgoing>Flow_ProductReady_Confirm</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ConfirmOrder" name="Confirm Order">
      <bpmn:incoming>Flow_ProductReady_Confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirm_ParallelSplit</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_ParallelSplit" name="Invoice and Ship" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_Confirm_ParallelSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_Parallel_Invoice</bpmn:outgoing>
      <bpmn:outgoing>Flow_Parallel_Ship</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sendTask id="SendTask_IssueInvoice" name="Issue Invoice" messageRef="Message_Invoice">
      <bpmn:incoming>Flow_Parallel_Invoice</bpmn:incoming>
      <bpmn:outgoing>Flow_Invoice_WaitPayment</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="CatchEvent_Payment" name="Payment Received">
      <bpmn:incoming>Flow_Invoice_WaitPayment</bpmn:incoming>
      <bpmn:outgoing>Flow_Payment_ParallelJoin</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Payment" messageRef="Message_Payment" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_ShipProduct" name="Ship Product">
      <bpmn:incoming>Flow_Parallel_Ship</bpmn:incoming>
      <bpmn:outgoing>Flow_Ship_ParallelJoin</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_ParallelJoin" name="Payment and Shipment Complete" gatewayDirection="Converging">
      <bpmn:incoming>Flow_Payment_ParallelJoin</bpmn:incoming>
      <bpmn:incoming>Flow_Ship_ParallelJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_Join_Archive</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_ArchiveOrder" name="Archive Order">
      <bpmn:incoming>Flow_Join_Archive</bpmn:incoming>
      <bpmn:outgoing>Flow_Archive_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_OrderArchived" name="Order Archived">
      <bpmn:incoming>Flow_Archive_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataStoreReference id="DataStoreReference_WarehouseDB" name="Warehouse Database" dataStoreRef="DataStore_WarehouseDB" />
    <bpmn:dataStoreReference id="DataStoreReference_SuppliersCatalog" name="Suppliers Catalog" dataStoreRef="DataStore_SuppliersCatalog" />
    <bpmn:sequenceFlow id="Flow_Start_CheckStock" sourceRef="StartEvent_PurchaseOrder" targetRef="ServiceTask_CheckStock" />
    <bpmn:sequenceFlow id="Flow_CheckStock_Gateway" sourceRef="ServiceTask_CheckStock" targetRef="Gateway_ProductInStock" />
    <bpmn:sequenceFlow id="Flow_StockYes" name="Yes" sourceRef="Gateway_ProductInStock" targetRef="Task_RetrieveProduct">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${productInStock}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_StockNo" name="No" sourceRef="Gateway_ProductInStock" targetRef="ServiceTask_CheckRawMaterials">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!productInStock}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CheckMaterials_SelectSuppliers" sourceRef="ServiceTask_CheckRawMaterials" targetRef="Gateway_SelectSuppliers" />
    <bpmn:sequenceFlow id="Flow_ToSupplier1" name="Supplier 1 materials required" sourceRef="Gateway_SelectSuppliers" targetRef="SendTask_OrderSupplier1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${requiresSupplier1Materials}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ToSupplier2" name="Supplier 2 materials required" sourceRef="Gateway_SelectSuppliers" targetRef="SendTask_OrderSupplier2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${requiresSupplier2Materials}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_OrderSupplier1_Wait" sourceRef="SendTask_OrderSupplier1" targetRef="CatchEvent_MaterialsSupplier1" />
    <bpmn:sequenceFlow id="Flow_Supplier1_Join" sourceRef="CatchEvent_MaterialsSupplier1" targetRef="Gateway_MaterialsReady" />
    <bpmn:sequenceFlow id="Flow_OrderSupplier2_Wait" sourceRef="SendTask_OrderSupplier2" targetRef="CatchEvent_MaterialsSupplier2" />
    <bpmn:sequenceFlow id="Flow_Supplier2_Join" sourceRef="CatchEvent_MaterialsSupplier2" targetRef="Gateway_MaterialsReady" />
    <bpmn:sequenceFlow id="Flow_MaterialsReady_Manufacture" sourceRef="Gateway_MaterialsReady" targetRef="Task_ManufactureProduct" />
    <bpmn:sequenceFlow id="Flow_Manufacture_ProductReady" sourceRef="Task_ManufactureProduct" targetRef="Gateway_ProductReady" />
    <bpmn:sequenceFlow id="Flow_Retrieve_ProductReady" sourceRef="Task_RetrieveProduct" targetRef="Gateway_ProductReady" />
    <bpmn:sequenceFlow id="Flow_ProductReady_Confirm" sourceRef="Gateway_ProductReady" targetRef="Task_ConfirmOrder" />
    <bpmn:sequenceFlow id="Flow_Confirm_ParallelSplit" sourceRef="Task_ConfirmOrder" targetRef="Gateway_ParallelSplit" />
    <bpmn:sequenceFlow id="Flow_Parallel_Invoice" sourceRef="Gateway_ParallelSplit" targetRef="SendTask_IssueInvoice" />
    <bpmn:sequenceFlow id="Flow_Parallel_Ship" sourceRef="Gateway_ParallelSplit" targetRef="Task_ShipProduct" />
    <bpmn:sequenceFlow id="Flow_Invoice_WaitPayment" sourceRef="SendTask_IssueInvoice" targetRef="CatchEvent_Payment" />
    <bpmn:sequenceFlow id="Flow_Payment_ParallelJoin" sourceRef="CatchEvent_Payment" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_Ship_ParallelJoin" sourceRef="Task_ShipProduct" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_Join_Archive" sourceRef="Gateway_ParallelJoin" targetRef="Task_ArchiveOrder" />
    <bpmn:sequenceFlow id="Flow_Archive_End" sourceRef="Task_ArchiveOrder" targetRef="EndEvent_OrderArchived" />
    <bpmn:association id="Association_CheckStock_WarehouseDB" associationDirection="Both" sourceRef="ServiceTask_CheckStock" targetRef="DataStoreReference_WarehouseDB" />
    <bpmn:association id="Association_CheckMaterials_Catalog" associationDirection="Both" sourceRef="ServiceTask_CheckRawMaterials" targetRef="DataStoreReference_SuppliersCatalog" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_OrderFulfillment">
    <bpmndi:BPMNPlane id="BPMNPlane_OrderFulfillment" bpmnElement="Collaboration_OrderFulfillment">
      <bpmndi:BPMNShape id="Shape_Participant_Customer" bpmnElement="Participant_Customer" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="2350" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Participant_Seller" bpmnElement="Participant_Seller" isHorizontal="true">
        <dc:Bounds x="160" y="200" width="2350" height="520" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_WarehouseDistribution" bpmnElement="Lane_WarehouseDistribution" isHorizontal="true">
        <dc:Bounds x="190" y="420" width="2320" height="300" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Sales" bpmnElement="Lane_Sales" isHorizontal="true">
        <dc:Bounds x="190" y="200" width="2320" height="220" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_StartEvent_PurchaseOrder" bpmnElement="StartEvent_PurchaseOrder">
        <dc:Bounds x="230" y="530" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="209" y="570" width="78" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ServiceTask_CheckStock" bpmnElement="ServiceTask_CheckStock">
        <dc:Bounds x="320" y="513" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ProductInStock" bpmnElement="Gateway_ProductInStock" isMarkerVisible="true">
        <dc:Bounds x="500" y="523" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="485" y="580" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ServiceTask_CheckRawMaterials" bpmnElement="ServiceTask_CheckRawMaterials">
        <dc:Bounds x="600" y="440" width="160" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_SelectSuppliers" bpmnElement="Gateway_SelectSuppliers" isMarkerVisible="true">
        <dc:Bounds x="810" y="450" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="785" y="505" width="100" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_SendTask_OrderSupplier1" bpmnElement="SendTask_OrderSupplier1">
        <dc:Bounds x="910" y="430" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_CatchEvent_MaterialsSupplier1" bpmnElement="CatchEvent_MaterialsSupplier1">
        <dc:Bounds x="1110" y="447" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1073" y="488" width="114" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_SendTask_OrderSupplier2" bpmnElement="SendTask_OrderSupplier2">
        <dc:Bounds x="910" y="605" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_CatchEvent_MaterialsSupplier2" bpmnElement="CatchEvent_MaterialsSupplier2">
        <dc:Bounds x="1110" y="622" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1073" y="662" width="114" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_MaterialsReady" bpmnElement="Gateway_MaterialsReady" isMarkerVisible="true">
        <dc:Bounds x="1210" y="523" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1181" y="575" width="108" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ManufactureProduct" bpmnElement="Task_ManufactureProduct">
        <dc:Bounds x="1310" y="505" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RetrieveProduct" bpmnElement="Task_RetrieveProduct">
        <dc:Bounds x="1310" y="615" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ProductReady" bpmnElement="Gateway_ProductReady" isMarkerVisible="true">
        <dc:Bounds x="1490" y="328" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1479" y="380" width="73" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ConfirmOrder" bpmnElement="Task_ConfirmOrder">
        <dc:Bounds x="1590" y="318" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ParallelSplit" bpmnElement="Gateway_ParallelSplit" isMarkerVisible="true">
        <dc:Bounds x="1760" y="328" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1745" y="380" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_SendTask_IssueInvoice" bpmnElement="SendTask_IssueInvoice">
        <dc:Bounds x="1860" y="240" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_CatchEvent_Payment" bpmnElement="CatchEvent_Payment">
        <dc:Bounds x="2040" y="257" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2011" y="295" width="93" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ShipProduct" bpmnElement="Task_ShipProduct">
        <dc:Bounds x="1860" y="570" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ParallelJoin" bpmnElement="Gateway_ParallelJoin" isMarkerVisible="true">
        <dc:Bounds x="2125" y="328" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2102" y="380" width="97" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ArchiveOrder" bpmnElement="Task_ArchiveOrder">
        <dc:Bounds x="2225" y="318" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_OrderArchived" bpmnElement="EndEvent_OrderArchived">
        <dc:Bounds x="2390" y="335" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2373" y="375" width="74" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_DataStoreReference_WarehouseDB" bpmnElement="DataStoreReference_WarehouseDB">
        <dc:Bounds x="350" y="615" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="347" y="665" width="56" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_DataStoreReference_SuppliersCatalog" bpmnElement="DataStoreReference_SuppliersCatalog">
        <dc:Bounds x="650" y="615" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="632" y="665" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Association_CheckStock_WarehouseDB" bpmnElement="Association_CheckStock_WarehouseDB">
        <di:waypoint x="385" y="583" />
        <di:waypoint x="375" y="615" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Association_CheckMaterials_Catalog" bpmnElement="Association_CheckMaterials_Catalog">
        <di:waypoint x="680" y="510" />
        <di:waypoint x="675" y="615" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_CheckStock" bpmnElement="Flow_Start_CheckStock">
