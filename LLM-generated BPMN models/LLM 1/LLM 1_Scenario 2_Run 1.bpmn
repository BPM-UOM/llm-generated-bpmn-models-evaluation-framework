<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_OrderFulfillment" targetNamespace="https://example.org/bpmn/order-fulfillment" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:message id="Message_PurchaseOrder" name="Purchase order" />
  <bpmn:message id="Message_Supplier1Order" name="Raw material order for Supplier 1" />
  <bpmn:message id="Message_Supplier1Delivery" name="Raw materials from Supplier 1" />
  <bpmn:message id="Message_Supplier2Order" name="Raw material order for Supplier 2" />
  <bpmn:message id="Message_Supplier2Delivery" name="Raw materials from Supplier 2" />
  <bpmn:message id="Message_Payment" name="Payment" />
  <bpmn:dataStore id="DataStore_WarehouseDB" name="Warehouse database" />
  <bpmn:dataStore id="DataStore_SuppliersCatalog" name="Suppliers catalog" />
  <bpmn:collaboration id="Collaboration_OrderFulfillment">
    <bpmn:participant id="Participant_Seller" name="Seller organization" processRef="Process_Seller" />
    <bpmn:participant id="Participant_Supplier1" name="Supplier 1" processRef="Process_Supplier1" />
    <bpmn:participant id="Participant_Supplier2" name="Supplier 2" processRef="Process_Supplier2" />
    <bpmn:messageFlow id="MessageFlow_OrderSupplier1" name="Raw material order" sourceRef="Task_OrderSupplier1" targetRef="StartEvent_Supplier1Order" />
    <bpmn:messageFlow id="MessageFlow_DeliverySupplier1" name="Raw materials delivered" sourceRef="EndEvent_Supplier1Delivery" targetRef="Task_ReceiveMaterial1" />
    <bpmn:messageFlow id="MessageFlow_OrderSupplier2" name="Raw material order" sourceRef="Task_OrderSupplier2" targetRef="StartEvent_Supplier2Order" />
    <bpmn:messageFlow id="MessageFlow_DeliverySupplier2" name="Raw materials delivered" sourceRef="EndEvent_Supplier2Delivery" targetRef="Task_ReceiveMaterial2" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Seller" name="Order fulfillment" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Seller">
      <bpmn:lane id="Lane_WarehouseDistribution" name="Warehouse &#38; distribution department">
        <bpmn:flowNodeRef>StartEvent_PurchaseOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_StockAvailable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetrieveProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckRawMaterials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SupplierSelection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceiveMaterial1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OrderSupplier2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceiveMaterial2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MaterialsJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManufactureProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ProductReady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipProduct</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Sales" name="Sales department">
        <bpmn:flowNodeRef>Task_ConfirmOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_PaymentReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArchiveOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_OrderArchived</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_PurchaseOrder" name="Purchase order received">
      <bpmn:outgoing>Flow_Start_CheckStock</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_PurchaseOrder" messageRef="Message_PurchaseOrder" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CheckStock" name="Check product stock in ERP">
      <bpmn:incoming>Flow_Start_CheckStock</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckStock_StockGateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_StockAvailable" name="Product in stock?" default="Flow_NotInStock">
      <bpmn:incoming>Flow_CheckStock_StockGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_InStock</bpmn:outgoing>
      <bpmn:outgoing>Flow_NotInStock</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_RetrieveProduct" name="Retrieve product from warehouse">
      <bpmn:incoming>Flow_InStock</bpmn:incoming>
      <bpmn:outgoing>Flow_Retrieve_ProductReady</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="Task_CheckRawMaterials" name="Check raw materials availability in ERP">
      <bpmn:incoming>Flow_NotInStock</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckMaterials_SupplierSelection</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:inclusiveGateway id="Gateway_SupplierSelection" name="Which supplier materials are required?">
      <bpmn:incoming>Flow_CheckMaterials_SupplierSelection</bpmn:incoming>
      <bpmn:outgoing>Flow_SelectSupplier1</bpmn:outgoing>
      <bpmn:outgoing>Flow_SelectSupplier2</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:sendTask id="Task_OrderSupplier1" name="Order raw materials from Supplier 1" messageRef="Message_Supplier1Order">
      <bpmn:incoming>Flow_SelectSupplier1</bpmn:incoming>
      <bpmn:outgoing>Flow_Order1_Receive1</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Task_ReceiveMaterial1" name="Receive raw materials from Supplier 1" messageRef="Message_Supplier1Delivery">
      <bpmn:incoming>Flow_Order1_Receive1</bpmn:incoming>
      <bpmn:outgoing>Flow_Receive1_MaterialsJoin</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:sendTask id="Task_OrderSupplier2" name="Order raw materials from Supplier 2" messageRef="Message_Supplier2Order">
      <bpmn:incoming>Flow_SelectSupplier2</bpmn:incoming>
      <bpmn:outgoing>Flow_Order2_Receive2</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Task_ReceiveMaterial2" name="Receive raw materials from Supplier 2" messageRef="Message_Supplier2Delivery">
      <bpmn:incoming>Flow_Order2_Receive2</bpmn:incoming>
      <bpmn:outgoing>Flow_Receive2_MaterialsJoin</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:inclusiveGateway id="Gateway_MaterialsJoin" name="Required raw materials obtained">
      <bpmn:incoming>Flow_Receive1_MaterialsJoin</bpmn:incoming>
      <bpmn:incoming>Flow_Receive2_MaterialsJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_MaterialsJoin_Manufacture</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:task id="Task_ManufactureProduct" name="Manufacture product">
      <bpmn:incoming>Flow_MaterialsJoin_Manufacture</bpmn:incoming>
      <bpmn:outgoing>Flow_Manufacture_ProductReady</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ProductReady" name="Product ready">
      <bpmn:incoming>Flow_Retrieve_ProductReady</bpmn:incoming>
      <bpmn:incoming>Flow_Manufacture_ProductReady</bpmn:incoming>
      <bpmn:outgoing>Flow_ProductReady_Confirm</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ConfirmOrder" name="Confirm order">
      <bpmn:incoming>Flow_ProductReady_Confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirm_ParallelSplit</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_ParallelSplit" name="Invoice and ship in parallel">
      <bpmn:incoming>Flow_Confirm_ParallelSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_Parallel_Invoice</bpmn:outgoing>
      <bpmn:outgoing>Flow_Parallel_Ship</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sendTask id="Task_EmitInvoice" name="Emit invoice">
      <bpmn:incoming>Flow_Parallel_Invoice</bpmn:incoming>
      <bpmn:outgoing>Flow_Invoice_Payment</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="Event_PaymentReceived" name="Payment received">
      <bpmn:incoming>Flow_Invoice_Payment</bpmn:incoming>
      <bpmn:outgoing>Flow_Payment_ParallelJoin</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Payment" messageRef="Message_Payment" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_ShipProduct" name="Ship product">
      <bpmn:incoming>Flow_Parallel_Ship</bpmn:incoming>
      <bpmn:outgoing>Flow_Ship_ParallelJoin</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_ParallelJoin" name="Payment received and product shipped">
      <bpmn:incoming>Flow_Payment_ParallelJoin</bpmn:incoming>
      <bpmn:incoming>Flow_Ship_ParallelJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_ParallelJoin_Archive</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_ArchiveOrder" name="Archive order">
      <bpmn:incoming>Flow_ParallelJoin_Archive</bpmn:incoming>
      <bpmn:outgoing>Flow_Archive_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_OrderArchived" name="Order archived">
      <bpmn:incoming>Flow_Archive_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataStoreReference id="DataStoreRef_WarehouseDB" name="Warehouse database" dataStoreRef="DataStore_WarehouseDB" />
    <bpmn:dataStoreReference id="DataStoreRef_SuppliersCatalog" name="Suppliers catalog" dataStoreRef="DataStore_SuppliersCatalog" />
    <bpmn:sequenceFlow id="Flow_Start_CheckStock" sourceRef="StartEvent_PurchaseOrder" targetRef="Task_CheckStock" />
    <bpmn:sequenceFlow id="Flow_CheckStock_StockGateway" sourceRef="Task_CheckStock" targetRef="Gateway_StockAvailable" />
    <bpmn:sequenceFlow id="Flow_InStock" name="Yes" sourceRef="Gateway_StockAvailable" targetRef="Task_RetrieveProduct">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">stockAvailable = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NotInStock" name="No" sourceRef="Gateway_StockAvailable" targetRef="Task_CheckRawMaterials" />
    <bpmn:sequenceFlow id="Flow_Retrieve_ProductReady" sourceRef="Task_RetrieveProduct" targetRef="Gateway_ProductReady" />
    <bpmn:sequenceFlow id="Flow_CheckMaterials_SupplierSelection" sourceRef="Task_CheckRawMaterials" targetRef="Gateway_SupplierSelection" />
    <bpmn:sequenceFlow id="Flow_SelectSupplier1" name="Supplier 1 materials required" sourceRef="Gateway_SupplierSelection" targetRef="Task_OrderSupplier1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">supplier1MaterialsRequired = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_SelectSupplier2" name="Supplier 2 materials required" sourceRef="Gateway_SupplierSelection" targetRef="Task_OrderSupplier2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">supplier2MaterialsRequired = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Order1_Receive1" sourceRef="Task_OrderSupplier1" targetRef="Task_ReceiveMaterial1" />
    <bpmn:sequenceFlow id="Flow_Receive1_MaterialsJoin" sourceRef="Task_ReceiveMaterial1" targetRef="Gateway_MaterialsJoin" />
    <bpmn:sequenceFlow id="Flow_Order2_Receive2" sourceRef="Task_OrderSupplier2" targetRef="Task_ReceiveMaterial2" />
    <bpmn:sequenceFlow id="Flow_Receive2_MaterialsJoin" sourceRef="Task_ReceiveMaterial2" targetRef="Gateway_MaterialsJoin" />
    <bpmn:sequenceFlow id="Flow_MaterialsJoin_Manufacture" sourceRef="Gateway_MaterialsJoin" targetRef="Task_ManufactureProduct" />
    <bpmn:sequenceFlow id="Flow_Manufacture_ProductReady" sourceRef="Task_ManufactureProduct" targetRef="Gateway_ProductReady" />
    <bpmn:sequenceFlow id="Flow_ProductReady_Confirm" sourceRef="Gateway_ProductReady" targetRef="Task_ConfirmOrder" />
    <bpmn:sequenceFlow id="Flow_Confirm_ParallelSplit" sourceRef="Task_ConfirmOrder" targetRef="Gateway_ParallelSplit" />
    <bpmn:sequenceFlow id="Flow_Parallel_Invoice" sourceRef="Gateway_ParallelSplit" targetRef="Task_EmitInvoice" />
    <bpmn:sequenceFlow id="Flow_Parallel_Ship" sourceRef="Gateway_ParallelSplit" targetRef="Task_ShipProduct" />
    <bpmn:sequenceFlow id="Flow_Invoice_Payment" sourceRef="Task_EmitInvoice" targetRef="Event_PaymentReceived" />
    <bpmn:sequenceFlow id="Flow_Payment_ParallelJoin" sourceRef="Event_PaymentReceived" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_Ship_ParallelJoin" sourceRef="Task_ShipProduct" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_ParallelJoin_Archive" sourceRef="Gateway_ParallelJoin" targetRef="Task_ArchiveOrder" />
    <bpmn:sequenceFlow id="Flow_Archive_End" sourceRef="Task_ArchiveOrder" targetRef="EndEvent_OrderArchived" />
    <bpmn:association id="Association_WarehouseDB" associationDirection="One" sourceRef="DataStoreRef_WarehouseDB" targetRef="Task_CheckStock" />
    <bpmn:association id="Association_SuppliersCatalog" associationDirection="One" sourceRef="DataStoreRef_SuppliersCatalog" targetRef="Task_CheckRawMaterials" />
  </bpmn:process>
  <bpmn:process id="Process_Supplier1" name="Supplier 1 fulfillment" isExecutable="false">
    <bpmn:startEvent id="StartEvent_Supplier1Order" name="Raw material order received">
      <bpmn:outgoing>Flow_S1_Start_Prepare</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Supplier1Order" messageRef="Message_Supplier1Order" />
    </bpmn:startEvent>
    <bpmn:task id="Task_Supplier1Prepare" name="Prepare raw materials">
      <bpmn:incoming>Flow_S1_Start_Prepare</bpmn:incoming>
      <bpmn:outgoing>Flow_S1_Prepare_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Supplier1Delivery" name="Raw materials delivered">
      <bpmn:incoming>Flow_S1_Prepare_End</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Supplier1Delivery" messageRef="Message_Supplier1Delivery" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_S1_Start_Prepare" sourceRef="StartEvent_Supplier1Order" targetRef="Task_Supplier1Prepare" />
    <bpmn:sequenceFlow id="Flow_S1_Prepare_End" sourceRef="Task_Supplier1Prepare" targetRef="EndEvent_Supplier1Delivery" />
  </bpmn:process>
  <bpmn:process id="Process_Supplier2" name="Supplier 2 fulfillment" isExecutable="false">
    <bpmn:startEvent id="StartEvent_Supplier2Order" name="Raw material order received">
      <bpmn:outgoing>Flow_S2_Start_Prepare</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Supplier2Order" messageRef="Message_Supplier2Order" />
    </bpmn:startEvent>
    <bpmn:task id="Task_Supplier2Prepare" name="Prepare raw materials">
      <bpmn:incoming>Flow_S2_Start_Prepare</bpmn:incoming>
      <bpmn:outgoing>Flow_S2_Prepare_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Supplier2Delivery" name="Raw materials delivered">
      <bpmn:incoming>Flow_S2_Prepare_End</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Supplier2Delivery" messageRef="Message_Supplier2Delivery" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_S2_Start_Prepare" sourceRef="StartEvent_Supplier2Order" targetRef="Task_Supplier2Prepare" />
    <bpmn:sequenceFlow id="Flow_S2_Prepare_End" sourceRef="Task_Supplier2Prepare" targetRef="EndEvent_Supplier2Delivery" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_OrderFulfillment">
    <bpmndi:BPMNPlane id="BPMNPlane_OrderFulfillment" bpmnElement="Collaboration_OrderFulfillment">
      <bpmndi:BPMNShape id="Shape_Participant_Seller" bpmnElement="Participant_Seller" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="2620" height="660" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Sales" bpmnElement="Lane_Sales" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="2590" height="230" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_WarehouseDistribution" bpmnElement="Lane_WarehouseDistribution" isHorizontal="true">
        <dc:Bounds x="190" y="290" width="2590" height="430" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_StartEvent_PurchaseOrder" bpmnElement="StartEvent_PurchaseOrder">
        <dc:Bounds x="230" y="405" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="210" y="441" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CheckStock" bpmnElement="Task_CheckStock">
        <dc:Bounds x="310" y="380" width="140" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_StockAvailable" bpmnElement="Gateway_StockAvailable" isMarkerVisible="true">
        <dc:Bounds x="500" y="398" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="483" y="448" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RetrieveProduct" bpmnElement="Task_RetrieveProduct">
        <dc:Bounds x="600" y="325" width="150" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CheckRawMaterials" bpmnElement="Task_CheckRawMaterials">
        <dc:Bounds x="600" y="500" width="160" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_SupplierSelection" bpmnElement="Gateway_SupplierSelection">
        <dc:Bounds x="810" y="518" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="799" y="568" width="73" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_OrderSupplier1" bpmnElement="Task_OrderSupplier1">
        <dc:Bounds x="920" y="390" width="170" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ReceiveMaterial1" bpmnElement="Task_ReceiveMaterial1">
        <dc:Bounds x="1140" y="390" width="180" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_OrderSupplier2" bpmnElement="Task_OrderSupplier2">
        <dc:Bounds x="920" y="595" width="170" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ReceiveMaterial2" bpmnElement="Task_ReceiveMaterial2">
        <dc:Bounds x="1140" y="595" width="180" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_MaterialsJoin" bpmnElement="Gateway_MaterialsJoin">
        <dc:Bounds x="1370" y="518" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1350" y="568" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ManufactureProduct" bpmnElement="Task_ManufactureProduct">
        <dc:Bounds x="1470" y="500" width="150" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ProductReady" bpmnElement="Gateway_ProductReady" isMarkerVisible="true">
        <dc:Bounds x="1670" y="398" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1661" y="448" width="69" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ConfirmOrder" bpmnElement="Task_ConfirmOrder">
        <dc:Bounds x="1770" y="130" width="130" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ParallelSplit" bpmnElement="Gateway_ParallelSplit">
        <dc:Bounds x="1950" y="148" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1935" y="198" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_EmitInvoice" bpmnElement="Task_EmitInvoice">
        <dc:Bounds x="2050" y="85" width="130" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_PaymentReceived" bpmnElement="Event_PaymentReceived">
        <dc:Bounds x="2240" y="110" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2214" y="146" width="89" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ShipProduct" bpmnElement="Task_ShipProduct">
        <dc:Bounds x="2050" y="385" width="130" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ParallelJoin" bpmnElement="Gateway_ParallelJoin">
        <dc:Bounds x="2340" y="148" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2321" y="198" width="89" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ArchiveOrder" bpmnElement="Task_ArchiveOrder">
        <dc:Bounds x="2440" y="130" width="130" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_OrderArchived" bpmnElement="EndEvent_OrderArchived">
        <dc:Bounds x="2620" y="155" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2602" y="191" width="73" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_DataStoreRef_WarehouseDB" bpmnElement="DataStoreRef_WarehouseDB">
        <dc:Bounds x="325" y="580" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="322" y="630" width="56" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_DataStoreRef_SuppliersCatalog" bpmnElement="DataStoreRef_SuppliersCatalog">
        <dc:Bounds x="650" y="640" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="633" y="690" width="85" height="14" />
        </bpmndi:BPMNLabel>
