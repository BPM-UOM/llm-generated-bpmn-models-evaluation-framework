<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_DrivingLicense" targetNamespace="https://example.org/bpmn/transport-driving-license" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:message id="Message_Application" name="Application, solemn declaration and supporting documents" />
  <bpmn:message id="Message_AdditionalDocumentsRequest" name="Request for additional information" />
  <bpmn:message id="Message_AdditionalDocuments" name="Requested supporting documents" />
  <bpmn:message id="Message_SubmissionCertificate" name="Certificate of Submission of Request" />
  <bpmn:message id="Message_ProvisionalLicense" name="Provisional driving license" />
  <bpmn:message id="Message_PrintPackage" name="Electronic information and print application with photograph and signature" />
  <bpmn:message id="Message_DrivingLicense" name="Driving license" />
  <bpmn:collaboration id="Collaboration_DrivingLicense">
    <bpmn:participant id="Participant_InterestedParty" name="Interested Party" />
    <bpmn:participant id="Participant_TransportService" name="Transport and Communications Service of the Regional Unit" processRef="Process_DrivingLicense" />
    <bpmn:participant id="Participant_PassportDirectorate" name="Passport Directorate of the Hellenic Police" />
    <bpmn:messageFlow id="MessageFlow_Application" name="Submit application and documents" sourceRef="Participant_InterestedParty" targetRef="StartEvent_ApplicationReceived" messageRef="Message_Application" />
    <bpmn:messageFlow id="MessageFlow_RequestAdditional" name="Request additional information" sourceRef="Task_InformOmissions" targetRef="Participant_InterestedParty" messageRef="Message_AdditionalDocumentsRequest" />
    <bpmn:messageFlow id="MessageFlow_AdditionalDocuments" name="Submit requested documents" sourceRef="Participant_InterestedParty" targetRef="CatchEvent_DocumentsSubmitted" messageRef="Message_AdditionalDocuments" />
    <bpmn:messageFlow id="MessageFlow_Certificate" name="Provide submission certificate" sourceRef="Task_ProvideCertificate" targetRef="Participant_InterestedParty" messageRef="Message_SubmissionCertificate" />
    <bpmn:messageFlow id="MessageFlow_ProvisionalLicense" name="Provide provisional driving license" sourceRef="Task_IssueProvisionalLicense" targetRef="Participant_InterestedParty" messageRef="Message_ProvisionalLicense" />
    <bpmn:messageFlow id="MessageFlow_PrintPackage" name="Send information and print application" sourceRef="Task_SendToPassportDirectorate" targetRef="Participant_PassportDirectorate" messageRef="Message_PrintPackage" />
    <bpmn:messageFlow id="MessageFlow_DrivingLicense" name="Hand over driving license in person" sourceRef="Task_HandOverLicense" targetRef="Participant_InterestedParty" messageRef="Message_DrivingLicense" />
  </bpmn:collaboration>
  <bpmn:process id="Process_DrivingLicense" name="Driving License Application and Issuance" isExecutable="false">
    <bpmn:startEvent id="StartEvent_ApplicationReceived" name="Application and supporting documents received">
      <bpmn:outgoing>Flow_Start_Receive</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Application" messageRef="Message_Application" />
    </bpmn:startEvent>
    <bpmn:receiveTask id="Task_ReceiveApplication" name="Receive application, solemn declaration and supporting documents">
      <bpmn:incoming>Flow_Start_Receive</bpmn:incoming>
      <bpmn:outgoing>Flow_Receive_Check</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:userTask id="Task_CheckDocuments" name="Check completeness and correctness of supporting documents">
      <bpmn:incoming>Flow_Receive_Check</bpmn:incoming>
      <bpmn:incoming>Flow_DocumentsSubmitted_Recheck</bpmn:incoming>
      <bpmn:outgoing>Flow_Check_OmissionsGateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Omissions" name="Omissions identified?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_Check_OmissionsGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Omissions_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Omissions_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_InformOmissions" name="Inform interested party that additional information is required">
      <bpmn:incoming>Flow_Omissions_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Inform_EventGateway</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:eventBasedGateway id="Gateway_WaitForDocumentsOrDeadline" name="Documents submitted or 15 days elapsed?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_Inform_EventGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Wait_DocumentsSubmitted</bpmn:outgoing>
      <bpmn:outgoing>Flow_Wait_Deadline</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="CatchEvent_DocumentsSubmitted" name="Requested documents submitted">
      <bpmn:incoming>Flow_Wait_DocumentsSubmitted</bpmn:incoming>
      <bpmn:outgoing>Flow_DocumentsSubmitted_Recheck</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_AdditionalDocuments" messageRef="Message_AdditionalDocuments" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="CatchEvent_DeadlineElapsed" name="15 days pass without submission">
      <bpmn:incoming>Flow_Wait_Deadline</bpmn:incoming>
      <bpmn:outgoing>Flow_Deadline_Terminate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_15Days">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_NoSubmission" name="Process terminated: requested documents not received">
      <bpmn:incoming>Flow_Deadline_Terminate</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TerminateEventDefinition_NoSubmission" />
    </bpmn:endEvent>
    <bpmn:userTask id="Task_RegisterApplication" name="Register the application">
      <bpmn:incoming>Flow_Omissions_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Register_Certificate</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="Task_ProvideCertificate" name="Give Certificate of Submission of Request to interested party">
      <bpmn:incoming>Flow_Register_Certificate</bpmn:incoming>
      <bpmn:outgoing>Flow_Certificate_ExpiryGateway</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="Gateway_LicenseExpiry" name="Current license expired or expires before new form is printed?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_Certificate_ExpiryGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Expiry_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Expiry_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_IssueProvisionalLicense" name="Issue provisional driving license">
      <bpmn:incoming>Flow_Expiry_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Provisional_Merge</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="Gateway_AfterProvisional" name="Continue issuance" gatewayDirection="Converging">
      <bpmn:incoming>Flow_Expiry_No</bpmn:incoming>
      <bpmn:incoming>Flow_Provisional_Merge</bpmn:incoming>
      <bpmn:outgoing>Flow_Merge_IssueLicense</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_IssueDrivingLicense" name="Issue driving license by electronic entry in the Driving License Register">
      <bpmn:incoming>Flow_Merge_IssueLicense</bpmn:incoming>
      <bpmn:outgoing>Flow_Issue_SendToPassport</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_SendAutomatedReminder" name="Send automated reminder to responsible official">
      <bpmn:incoming>Flow_Reminder_Send</bpmn:incoming>
      <bpmn:outgoing>Flow_Reminder_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_ReminderSent" name="Reminder sent">
      <bpmn:incoming>Flow_Reminder_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_SendToPassportDirectorate" name="Send electronic information and print application with photograph and signature to Passport Directorate">
      <bpmn:incoming>Flow_Issue_SendToPassport</bpmn:incoming>
      <bpmn:outgoing>Flow_SendToPassport_HandOver</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Task_HandOverLicense" name="Hand over driving license in person at the submitting Service">
      <bpmn:incoming>Flow_SendToPassport_HandOver</bpmn:incoming>
      <bpmn:outgoing>Flow_HandOver_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_LicenseReceived" name="Interested party receives driving license">
      <bpmn:incoming>Flow_HandOver_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_ReminderEvery5WorkingDays" name="Every 5 working days while license is not issued" cancelActivity="false" attachedToRef="Task_IssueDrivingLicense">
      <bpmn:outgoing>Flow_Reminder_Send</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_5WorkingDays">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression" language="urn:calendar:working-days">R/5WD</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_Start_Receive" sourceRef="StartEvent_ApplicationReceived" targetRef="Task_ReceiveApplication" />
    <bpmn:sequenceFlow id="Flow_Receive_Check" sourceRef="Task_ReceiveApplication" targetRef="Task_CheckDocuments" />
    <bpmn:sequenceFlow id="Flow_DocumentsSubmitted_Recheck" sourceRef="CatchEvent_DocumentsSubmitted" targetRef="Task_CheckDocuments" />
    <bpmn:sequenceFlow id="Flow_Check_OmissionsGateway" sourceRef="Task_CheckDocuments" targetRef="Gateway_Omissions" />
    <bpmn:sequenceFlow id="Flow_Omissions_Yes" name="Yes" sourceRef="Gateway_Omissions" targetRef="Task_InformOmissions">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${omissionsIdentified}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Omissions_No" name="No" sourceRef="Gateway_Omissions" targetRef="Task_RegisterApplication">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!omissionsIdentified}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Inform_EventGateway" sourceRef="Task_InformOmissions" targetRef="Gateway_WaitForDocumentsOrDeadline" />
    <bpmn:sequenceFlow id="Flow_Wait_DocumentsSubmitted" sourceRef="Gateway_WaitForDocumentsOrDeadline" targetRef="CatchEvent_DocumentsSubmitted" />
    <bpmn:sequenceFlow id="Flow_Wait_Deadline" sourceRef="Gateway_WaitForDocumentsOrDeadline" targetRef="CatchEvent_DeadlineElapsed" />
    <bpmn:sequenceFlow id="Flow_Deadline_Terminate" sourceRef="CatchEvent_DeadlineElapsed" targetRef="EndEvent_NoSubmission" />
    <bpmn:sequenceFlow id="Flow_Register_Certificate" sourceRef="Task_RegisterApplication" targetRef="Task_ProvideCertificate" />
    <bpmn:sequenceFlow id="Flow_Certificate_ExpiryGateway" sourceRef="Task_ProvideCertificate" targetRef="Gateway_LicenseExpiry" />
    <bpmn:sequenceFlow id="Flow_Expiry_Yes" name="Yes" sourceRef="Gateway_LicenseExpiry" targetRef="Task_IssueProvisionalLicense">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${licenseExpiredOrExpiresBeforePrinting}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Expiry_No" name="No" sourceRef="Gateway_LicenseExpiry" targetRef="Gateway_AfterProvisional">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!licenseExpiredOrExpiresBeforePrinting}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Provisional_Merge" sourceRef="Task_IssueProvisionalLicense" targetRef="Gateway_AfterProvisional" />
    <bpmn:sequenceFlow id="Flow_Merge_IssueLicense" sourceRef="Gateway_AfterProvisional" targetRef="Task_IssueDrivingLicense" />
    <bpmn:sequenceFlow id="Flow_Issue_SendToPassport" sourceRef="Task_IssueDrivingLicense" targetRef="Task_SendToPassportDirectorate" />
    <bpmn:sequenceFlow id="Flow_Reminder_Send" sourceRef="BoundaryEvent_ReminderEvery5WorkingDays" targetRef="Task_SendAutomatedReminder" />
    <bpmn:sequenceFlow id="Flow_Reminder_End" sourceRef="Task_SendAutomatedReminder" targetRef="EndEvent_ReminderSent" />
    <bpmn:sequenceFlow id="Flow_SendToPassport_HandOver" sourceRef="Task_SendToPassportDirectorate" targetRef="Task_HandOverLicense" />
    <bpmn:sequenceFlow id="Flow_HandOver_End" sourceRef="Task_HandOverLicense" targetRef="EndEvent_LicenseReceived" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_DrivingLicense">
    <bpmndi:BPMNPlane id="BPMNPlane_DrivingLicense" bpmnElement="Collaboration_DrivingLicense">
      <bpmndi:BPMNShape id="Shape_Participant_InterestedParty" bpmnElement="Participant_InterestedParty" isHorizontal="true">
