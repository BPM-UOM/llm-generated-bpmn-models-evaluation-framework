      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Receive_Check" bpmnElement="Flow_Receive_Check">
        <di:waypoint x="425" y="360" />
        <di:waypoint x="470" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Recheck" bpmnElement="Flow_DocumentsSubmitted_Recheck">
        <di:waypoint x="1103" y="190" />
        <di:waypoint x="1103" y="175" />
        <di:waypoint x="545" y="175" />
        <di:waypoint x="545" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Check_Gateway" bpmnElement="Flow_Check_OmissionsGateway">
        <di:waypoint x="620" y="360" />
        <di:waypoint x="665" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Omissions_Yes" bpmnElement="Flow_Omissions_Yes">
