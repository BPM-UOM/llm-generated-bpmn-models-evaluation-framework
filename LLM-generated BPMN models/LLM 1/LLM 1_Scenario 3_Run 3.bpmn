        <di:waypoint x="955" y="445" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Certificate_Expiry" bpmnElement="Flow_Certificate_ExpiryGateway">
        <di:waypoint x="1110" y="445" />
        <di:waypoint x="1160" y="445" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Expiry_Yes" bpmnElement="Flow_Expiry_Yes">
        <di:waypoint x="1185" y="470" />
        <di:waypoint x="1185" y="560" />
        <di:waypoint x="1260" y="560" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1194" y="516" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Expiry_No" bpmnElement="Flow_Expiry_No">
        <di:waypoint x="1210" y="445" />
        <di:waypoint x="1450" y="445" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1318" y="427" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Provisional_Merge" bpmnElement="Flow_Provisional_Merge">
        <di:waypoint x="1405" y="560" />
        <di:waypoint x="1475" y="560" />
