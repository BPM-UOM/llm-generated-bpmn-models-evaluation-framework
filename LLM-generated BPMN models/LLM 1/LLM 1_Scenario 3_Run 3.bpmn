        <di:waypoint x="925" y="255" />
        <di:waypoint x="975" y="255" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Wait_Documents" bpmnElement="Flow_Wait_DocumentsSubmitted">
        <di:waypoint x="1025" y="255" />
        <di:waypoint x="1055" y="255" />
