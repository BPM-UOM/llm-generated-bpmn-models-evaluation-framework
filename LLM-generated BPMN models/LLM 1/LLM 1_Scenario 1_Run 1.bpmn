<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_ClaimsHandling" targetNamespace="http://example.com/bpmn/claims-handling" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Process_ClaimsHandling" name="Claims Handling Review Process" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_SeniorClaimsOfficer" name="Senior Claims Officer">
        <bpmn:flowNodeRef>Task_CheckRecommendation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ClaimStatus</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ClaimsOfficer" name="Claims Officer">
        <bpmn:flowNodeRef>Task_ExamineClaim</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_WriteRecommendation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ProceedClaimHandling</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_ClaimRegistered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Completed</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_ClaimRegistered" name="Claim registered">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_ExamineClaim" name="Examine claim">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_WriteRecommendation" name="Write settlement recommendation">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:incoming>Flow_NotOK</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_CheckRecommendation" name="Check settlement recommendation">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ClaimStatus" name="Claim OK?" default="Flow_NotOK">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_OK</bpmn:outgoing>
      <bpmn:outgoing>Flow_NotOK</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ProceedClaimHandling" name="Proceed with claim handling">
      <bpmn:incoming>Flow_OK</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Completed" name="Review completed">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_ClaimRegistered" targetRef="Task_ExamineClaim" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ExamineClaim" targetRef="Task_WriteRecommendation" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_WriteRecommendation" targetRef="Task_CheckRecommendation" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_CheckRecommendation" targetRef="Gateway_ClaimStatus" />
    <bpmn:sequenceFlow id="Flow_OK" name="OK" sourceRef="Gateway_ClaimStatus" targetRef="Task_ProceedClaimHandling">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">status = "OK"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NotOK" name="Not OK" sourceRef="Gateway_ClaimStatus" targetRef="Task_WriteRecommendation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">status = "Not OK"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_ProceedClaimHandling" targetRef="EndEvent_Completed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_ClaimsHandling">
    <bpmndi:BPMNPlane id="BPMNPlane_ClaimsHandling" bpmnElement="Process_ClaimsHandling">
      <bpmndi:BPMNShape id="Lane_ClaimsOfficer_di" bpmnElement="Lane_ClaimsOfficer" isHorizontal="true">
        <dc:Bounds x="160" y="100" width="1200" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_SeniorClaimsOfficer_di" bpmnElement="Lane_SeniorClaimsOfficer" isHorizontal="true">
        <dc:Bounds x="160" y="280" width="1200" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_ClaimRegistered_di" bpmnElement="StartEvent_ClaimRegistered">
        <dc:Bounds x="210" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="188" y="212" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ExamineClaim_di" bpmnElement="Task_ExamineClaim">
        <dc:Bounds x="300" y="150" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_WriteRecommendation_di" bpmnElement="Task_WriteRecommendation">
        <dc:Bounds x="490" y="150" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckRecommendation_di" bpmnElement="Task_CheckRecommendation">
        <dc:Bounds x="740" y="330" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ClaimStatus_di" bpmnElement="Gateway_ClaimStatus" isMarkerVisible="true">
        <dc:Bounds x="990" y="345" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="988" y="400" width="54" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProceedClaimHandling_di" bpmnElement="Task_ProceedClaimHandling">
        <dc:Bounds x="1100" y="150" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Completed_di" bpmnElement="EndEvent_Completed">
        <dc:Bounds x="1310" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1283" y="212" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="246" y="190" />
        <di:waypoint x="300" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="190" />
        <di:waypoint x="490" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="670" y="190" />
        <di:waypoint x="705" y="190" />
        <di:waypoint x="705" y="370" />
        <di:waypoint x="740" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="920" y="370" />
        <di:waypoint x="990" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_OK_di" bpmnElement="Flow_OK">
        <di:waypoint x="1015" y="345" />
        <di:waypoint x="1015" y="190" />
        <di:waypoint x="1100" y="190" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1032" y="251" width="16" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotOK_di" bpmnElement="Flow_NotOK">
        <di:waypoint x="1015" y="395" />
        <di:waypoint x="1015" y="440" />
        <di:waypoint x="580" y="440" />
        <di:waypoint x="580" y="230" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="782" y="446" width="37" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="1270" y="190" />
        <di:waypoint x="1310" y="190" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
